.page {
  position: relative;
  height: 100vh;
  background: #fdf1f5;
  overflow: hidden;
}

.map {
  width: 100%;
  height: 100vh;
}

.top-tabs {
  position: absolute;
  top: 20rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 20;
  display: flex;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 999rpx;
  padding: 8rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding: 16rpx 0;
  border-radius: 999rpx;
}

.tab-item.active {
  background: #fff1f4;
  color: #ff6b81;
  font-weight: 700;
}

.tip-bar {
  position: absolute;
  top: 165rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 15;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.05);
}

.bottom-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 420rpx;
  background: rgba(255, 255, 255, 0.98);
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  z-index: 20;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.06);
  padding-top: 12rpx;
  box-sizing: border-box;
}

.panel-header {
  padding: 0 24rpx 12rpx;
}

.drag-line {
  width: 90rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #e8dbe0;
  margin: 0 auto 16rpx;
}

.panel-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
}

.card-swiper {
  width: 100%;
  height: 320rpx;
  margin-top: 6rpx;
}

.card {
  height: 280rpx;
  background: #fff;
  border-radius: 24rpx;
  margin: 20rpx 0 0 0;
  display: flex;
  padding: 20rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid transparent;
}

.card-active {
  border-color: #ffb7c5;
  box-shadow: 0 12rpx 28rpx rgba(255, 107, 129, 0.12);
}

.card-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.card-content {
  margin-left: 20rpx;
  flex: 1;
}

.card-top-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.4;
  max-width: 280rpx;
}

.card-tag {
  font-size: 22rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  white-space: nowrap;
}

.lost-tag {
  color: #ff8a00;
  background: #fff3dd;
}

.found-tag {
  color: #2db36c;
  background: #e9f9f0;
}

.card-line {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.distance-line {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #ff6b81;
  font-weight: 600;
}

.detail-btn {
  margin-top: 18rpx;
  width: 180rpx;
  height: 64rpx;
  line-height: 64rpx;
  background: #ff6b81;
  color: #fff;
  border-radius: 999rpx;
  font-size: 26rpx;
}

.empty-wrap {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 80rpx 24rpx 0;
}
.radius-wrap {
  position: absolute;
  top: 100rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 18;
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.radius-item {
  font-size: 24rpx;
  color: #999;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.05);
}

.radius-item.active {
  color: #ff6b81;
  background: #fff1f4;
  font-weight: 700;
}