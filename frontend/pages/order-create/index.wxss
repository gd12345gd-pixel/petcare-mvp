.content {
  height: calc(100vh - 96rpx - 156rpx);
}

.address-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.address-main {
  flex: 1;
  min-width: 0;
}

.address-title {
  line-height: 1.4;
}

.address-sub {
  margin-top: 10rpx;
}

.pet-header {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.pet-header-desc {
  line-height: 1.5;
}

.pet-scroll {
  margin-top: 22rpx;
  white-space: nowrap;
}

.pet-row {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 8rpx;
}

.pet-card {
  width: 176rpx;
  background: #f8f9fc;
  border-radius: 20rpx;
  padding: 14rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.pet-card.active {
  background: #fff7f9;
  border-color: #ff9ab0;
  box-shadow: 0 6rpx 16rpx rgba(255, 122, 160, 0.12);
}

.pet-card-image {
  width: 100%;
  height: 120rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
}

.pet-card-name {
  margin-top: 12rpx;
  line-height: 1.3;
}

.pet-card-meta {
  margin-top: 6rpx;
}

.add-card {
  border: 2rpx dashed #d8dde6;
  background: #fafbfc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid #d0d5dd;
  color: #8f96a3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  line-height: 1;
}

.add-text {
  margin-top: 18rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
  line-height: 1;
}

.pet-empty-wrap {
  margin-top: 24rpx;
  background: #fafbfc;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
}

.pet-empty-btn {
  margin: 18rpx auto 0;
  width: 220rpx;
}

.selector-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
}

.selector-left {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.selector-title {
  line-height: 1.4;
}

.selector-right {
  flex: 1;
  min-width: 0;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.selector-value-wrap {
  min-width: 0;
  max-width: 390rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.selector-value {
  font-size: 26rpx;
  color: #a0a0a0;
  line-height: 42rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: right;
}

.selector-value.active {
  color: #222;
}

.note-textarea {
  min-height: 180rpx;
}

.bottom-tip {
  text-align: center;
  font-size: 22rpx;
  color: #8c8c8c;
  margin-top: 24rpx;
  line-height: 1.5;
  padding: 0 24rpx;
}

.submit-btn {
  width: 100%;
  box-shadow: 0 10rpx 20rpx rgba(255, 122, 0, 0.18);
}

.mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 99;
}

.time-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  z-index: 100;
  padding: 24rpx 24rpx 30rpx;
  box-sizing: border-box;
  max-height: 82vh;
  overflow-y: auto;
}

.time-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.time-popup-title {
  line-height: 1.4;
}

.time-popup-close {
  font-size: 30rpx;
  color: #b4b4b4;
  width: 48rpx;
  text-align: center;
}

.week-row {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
}

.week-item {
  text-align: center;
  font-size: 24rpx;
  color: #808080;
  padding: 10rpx 0;
}

.weekend {
  color: #ff6b81;
}

.calendar-grid {
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx 6rpx;
}

.day-cell {
  height: 78rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.day-cell.empty {
  visibility: hidden;
}

.day-cell.selected {
  background: #ff6b81;
  color: #fff;
}

.day-num {
  font-size: 28rpx;
  font-weight: 600;
}

.time-section-title {
  margin-top: 28rpx;
  text-align: center;
}

.slot-grid {
  margin-top: 22rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.slot-item {
  position: relative;
  min-width: 190rpx;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 2rpx solid #eceef2;
  color: #666;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.slot-item.active {
  border-color: #ff6b81;
  color: #ff6b81;
  background: #fff7f9;
}

.recommend-tag {
  position: absolute;
  top: -16rpx;
  right: 10rpx;
  background: #ff5f8d;
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  line-height: 1.2;
}

.time-tip {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #ff6b81;
  line-height: 1.5;
}

.time-popup-btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}

.popup-cancel-btn,
.popup-confirm-btn {
  flex: 1;
}