.page {
  min-height: 100vh;
  background: #f6f7fb;
  box-sizing: border-box;
  padding-bottom: 150rpx;
}

.nav-bar {
  height: 96rpx;
  display: flex;
  align-items: center;
  position: relative;
  padding: 0 24rpx;
  background: #ffffff;
  border-bottom: 8rpx solid #f3f4f7;
}

.back-area {
  font-size: 36rpx;
  color: #222;
  width: 64rpx;
  line-height: 1;
}

.nav-title {
  position: absolute;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
  color: #111;
}

.section-card {
  margin-top: 16rpx;
  background: #fff;
  padding: 28rpx 24rpx;
  box-sizing: border-box;
}

.address-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.address-main {
  flex: 1;
}

.address-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #222;
  line-height: 1.4;
}

.address-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8c8c8c;
  line-height: 1.5;
}

.arrow {
  font-size: 36rpx;
  color: #b6b6b6;
  margin-left: 18rpx;
}

.block-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.block-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
  white-space: nowrap;
}

.block-subtext {
  font-size: 24rpx;
  color: #9a9a9a;
  line-height: 1.5;
}

.pet-scroll {
  margin-top: 22rpx;
  white-space: nowrap;
}

.pet-row {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 8rpx;
}

.pet-card {
  width: 176rpx;
  background: #f8f9fc;
  border-radius: 20rpx;
  padding: 14rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.pet-card.active {
  background: #fff7f9;
  border-color: #ff9ab0;
  box-shadow: 0 6rpx 16rpx rgba(255, 122, 160, 0.12);
}

.pet-card-image {
  width: 100%;
  height: 120rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
}

.pet-card-name {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.3;
}

.pet-card-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8c8c8c;
  line-height: 1.5;
}

.add-card {
  border: 2rpx dashed #d8dde6;
  background: #fafbfc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid #d0d5dd;
  color: #8f96a3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  line-height: 1;
}

.add-text {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

.pet-empty-wrap {
  margin-top: 24rpx;
  background: #fafbfc;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
}

.pet-empty-text {
  font-size: 24rpx;
  color: #8c8c8c;
  line-height: 1.6;
}

.pet-empty-btn {
  margin-top: 18rpx;
  width: 220rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 16rpx;
  background: #ff7a00;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
}

.selector-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
}

.selector-left {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.selector-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
}

.selector-right {
  flex: 1;
  min-width: 0;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.selector-value-wrap {
  min-width: 0;
  max-width: 390rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.selector-value {
  font-size: 26rpx;
  color: #a0a0a0;
  line-height: 42rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: right;
}

.selector-value.active {
  color: #222;
}

.selector-arrow {
  width: 24rpx;
  height: 42rpx;
  margin-left: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #b6b6b6;
  font-size: 30rpx;
  line-height: 42rpx;
  flex-shrink: 0;
}

.field-block {
  margin-top: 24rpx;
}

.field-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 14rpx;
  line-height: 1.4;
}

.input {
  width: 100%;
  height: 84rpx;
  background: #f7f8fb;
  border-radius: 18rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #222;
  border: 1rpx solid #edf0f4;
}

.input-placeholder {
  color: #b3b7c0;
  font-size: 26rpx;
  line-height: 1.5;
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  background: #f7f8fb;
  border-radius: 18rpx;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #222;
  border: 1rpx solid #edf0f4;
  line-height: 1.6;
}

.textarea.small {
  min-height: 150rpx;
}

.bottom-tip {
  text-align: center;
  font-size: 22rpx;
  color: #8c8c8c;
  margin-top: 28rpx;
  line-height: 1.5;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.96);
  padding: 16rpx 20rpx 26rpx;
  box-sizing: border-box;
  border-top: 1rpx solid #f0f0f0;
  backdrop-filter: blur(10rpx);
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #ff9200 0%, #ff7a00 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 20rpx rgba(255, 122, 0, 0.18);
}

.mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 99;
}

.time-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  z-index: 100;
  padding: 24rpx 24rpx 30rpx;
  box-sizing: border-box;
  max-height: 82vh;
  overflow-y: auto;
}

.time-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.time-popup-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
}

.time-popup-close {
  font-size: 30rpx;
  color: #b4b4b4;
  width: 48rpx;
  text-align: center;
}

.week-row {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
}

.week-item {
  text-align: center;
  font-size: 24rpx;
  color: #808080;
  padding: 10rpx 0;
}

.weekend {
  color: #ff6b81;
}

.calendar-grid {
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx 6rpx;
}

.day-cell {
  height: 78rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.day-cell.empty {
  visibility: hidden;
}

.day-cell.selected {
  background: #ff6b81;
  color: #fff;
}

.day-num {
  font-size: 28rpx;
  font-weight: 600;
}

.time-section-title {
  margin-top: 28rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
  text-align: center;
}

.slot-grid {
  margin-top: 22rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.slot-item {
  position: relative;
  min-width: 190rpx;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 2rpx solid #eceef2;
  color: #666;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.slot-item.active {
  border-color: #ff6b81;
  color: #ff6b81;
  background: #fff7f9;
}

.recommend-tag {
  position: absolute;
  top: -16rpx;
  right: 10rpx;
  background: #ff5f8d;
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  line-height: 1.2;
}

.time-tip {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #ff6b81;
  line-height: 1.5;
}

.time-popup-btn-row,
.popup-btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}

.popup-cancel-btn,
.popup-confirm-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.popup-cancel-btn {
  background: #f3f4f6;
  color: #999;
}

.popup-confirm-btn {
  background: #ff5f8d;
  color: #fff;
}

.pet-popup {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  z-index: 100;
  box-sizing: border-box;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #222;
  margin-bottom: 8rpx;
}

.pet-type-row {
  display: flex;
  gap: 12rpx;
}

.pet-type-item {
  flex: 1;
  height: 72rpx;
  border-radius: 16rpx;
  background: #f3f4f6;
  color: #333;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pet-type-item.active {
  background: #ff7a00;
  color: #fff;
  font-weight: 700;
}

.upload-box {
  height: 170rpx;
  border: 2rpx dashed #d7dbe3;
  border-radius: 18rpx;
  background: #fafbfc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 42rpx;
  color: #9aa3af;
  margin-bottom: 8rpx;
  line-height: 1;
}

.upload-text {
  font-size: 24rpx;
  color: #666;
}

.preview-img {
  width: 100%;
  height: 190rpx;
  border-radius: 18rpx;
  background: #f5f5f5;
}