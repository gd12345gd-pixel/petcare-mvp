<view class="page-with-bottom-bar">
  <view class="nav-bar nav-bar-pink">
    <view class="back-area" bindtap="navigateBack">
      <view class="back-icon"></view>
    </view>
    <view class="nav-title">下单</view>
  </view>

  <scroll-view class="content" scroll-y>
    <view class="section-card address-section" bindtap="goChooseAddress">
      <view class="address-main">
        <view class="card-title address-title">
          {{selectedAddress ? (selectedAddress.contactName + ' ' + selectedAddress.contactPhone) : '点击添加服务地址'}}
        </view>
        <view class="desc-text address-sub" wx:if="{{selectedAddress}}">
          {{selectedAddress.fullAddress}}
        </view>
      </view>
      <view class="arrow">›</view>
    </view>

    <view class="section-card">
      <view class="pet-header">
        <view class="card-title">服务宠物</view>
        <view class="desc-text pet-header-desc">未添加的宠物宠托师将不提供服务哦～</view>
      </view>

      <scroll-view class="pet-scroll" scroll-x wx:if="{{pets.length}}">
        <view class="pet-row">
          <view
            class="pet-card {{selectedPetId === item.id ? 'active' : ''}}"
            wx:for="{{pets}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="selectPet"
          >
            <image class="pet-card-image" src="{{item.avatarUrl || item.imageUrl}}" mode="aspectFill" />
            <view class="block-title pet-card-name">{{item.name}}</view>
            <view class="desc-text pet-card-meta">{{item.type}}{{item.breed ? ' · ' + item.breed : ''}}</view>
          </view>

          <view class="pet-card add-card" bindtap="goAddPet">
            <view class="add-circle">+</view>
            <view class="add-text">添加宠物</view>
          </view>
        </view>
      </scroll-view>

      <view class="pet-empty-wrap" wx:else>
        <view class="empty-desc">还没有宠物，先新增一个吧</view>
        <button class="primary-btn pet-empty-btn" bindtap="goAddPet">新增宠物</button>
      </view>
    </view>

    <view class="section-card selector-row" bindtap="openTimePopup">
      <view class="selector-left">
        <view class="card-title selector-title">服务时间</view>
      </view>

      <view class="selector-right">
        <view class="selector-value-wrap">
          <view class="{{selectedTimeSummary ? 'selector-value active' : 'selector-value'}}">
            {{selectedTimeSummary || '请选择服务时间'}}
          </view>
        </view>
        <view class="arrow">›</view>
      </view>
    </view>

    <view class="section-card">
      <view class="field-label">服务费用（元）</view>
      <input
        class="input"
        placeholder="请输入服务费用"
        placeholder-class="input-placeholder"
        type="digit"
        value="{{form.serviceFee}}"
        data-field="serviceFee"
        bindinput="onInput"
      />
    </view>

    <view class="section-card">
      <view class="field-label">照护备注</view>
      <textarea
        class="textarea note-textarea"
        placeholder="可填写宠物习性、喂养方式、注意事项、是否怕生等"
        placeholder-class="input-placeholder"
        value="{{form.specialRequirement}}"
        data-field="specialRequirement"
        bindinput="onInput"
        maxlength="300"
      />
    </view>

    <view class="bottom-tip">提交订单前请确认地址、宠物和服务时间</view>
  </scroll-view>

  <view class="bottom-bar">
    <button class="primary-btn submit-btn" bindtap="submitOrder">下一步：支付费用</button>
  </view>

  <view class="mask" wx:if="{{showTimePopup}}" bindtap="closeTimePopup"></view>
  <view class="time-popup" wx:if="{{showTimePopup}}">
    <view class="time-popup-header">
      <view class="card-title time-popup-title">{{calendarMonthText}}</view>
      <view class="time-popup-close" bindtap="closeTimePopup">✕</view>
    </view>

    <view class="week-row">
      <view class="week-item">日</view>
      <view class="week-item">一</view>
      <view class="week-item">二</view>
      <view class="week-item">三</view>
      <view class="week-item">四</view>
      <view class="week-item">五</view>
      <view class="week-item weekend">六</view>
    </view>

    <view class="calendar-grid">
      <view
        wx:for="{{calendarDays}}"
        wx:key="id"
        class="day-cell {{item.empty ? 'empty' : ''}} {{item.selected ? 'selected' : ''}}"
        data-date="{{item.date}}"
        bindtap="toggleDateSelect"
      >
        <block wx:if="{{!item.empty}}">
          <view class="day-num">{{item.day}}</view>
        </block>
      </view>
    </view>

    <view class="card-title time-section-title">选择期望上门服务时间段</view>

    <view class="slot-grid">
      <view
        class="slot-item {{item.selected ? 'active' : ''}}"
        wx:for="{{timeSlots}}"
        wx:key="value"
        data-value="{{item.value}}"
        bindtap="toggleTimeSlot"
      >
        <view class="recommend-tag" wx:if="{{item.recommend}}">推荐</view>
        {{item.label}}
      </view>
    </view>

    <view class="time-tip">* 需要多个上门时间段可多选哦~</view>

    <view class="time-popup-btn-row">
      <button class="secondary-btn popup-cancel-btn" bindtap="closeTimePopup">取消</button>
      <button class="pink-btn popup-confirm-btn" bindtap="confirmTimeSelection">下一步</button>
    </view>
  </view>
</view>