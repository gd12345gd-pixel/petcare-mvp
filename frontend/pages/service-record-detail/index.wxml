<view class="page">
  <view class="header-card">
    <view class="title">服务记录</view>
    <view class="info">订单号：{{orderNo || ('#' + orderId)}}</view>
    <view class="info" wx:if="{{serviceDate}}">服务时间：{{serviceDate}} {{timeSlot}}</view>
  </view>

  <view class="action-bar">
    <button class="upload-btn" bindtap="goUpload">去上传服务记录</button>
  </view>

  <view class="timeline" wx:if="{{records.length}}">
    <view class="timeline-item" wx:for="{{records}}" wx:key="id">
      <view class="dot"></view>
      <view class="content-card">
        <view class="top-row">
          <text class="time">{{item.createdAt}}</text>
          <text class="tag">{{item.typeText}}</text>
        </view>

        <image
          wx:if="{{item.imageUrl}}"
          class="record-img"
          src="{{item.imageUrl}}"
          mode="aspectFill"
          data-url="{{item.imageUrl}}"
          bindtap="previewImage"
        ></image>

        <video
          wx:if="{{item.videoUrl}}"
          class="record-video"
          src="{{item.videoUrl}}"
          controls
          objectFit="cover"
          show-center-play-btn="{{true}}"
        ></video>

        <view class="desc" wx:if="{{item.description}}">
          {{item.description}}
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:else>
    暂无服务记录
  </view>
</view>