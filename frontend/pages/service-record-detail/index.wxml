<view class="record-detail-page">
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-side nav-left" bindtap="navigateBack">‹</view>
      <view class="nav-title">服务记录详情</view>
      <view class="nav-side"></view>
    </view>
  </view>

  <scroll-view class="content" scroll-y style="height: calc(100vh - {{navTotalHeight}}px);">
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-text">加载中...</view>
    </view>

    <block wx:elif="{{record}}">
      <view class="status-card">
        <view class="status-title">服务记录已提交</view>
        <view class="status-desc">本次上门服务情况如下</view>
      </view>

      <view class="section-card" wx:if="{{record.imageUrls && record.imageUrls.length}}">
        <view class="section-title">服务照片</view>
        <scroll-view class="image-scroll" scroll-x>
          <view class="image-row">
            <image
              class="record-image"
              wx:for="{{record.imageUrls}}"
              wx:key="*this"
              src="{{item}}"
              mode="aspectFill"
              data-url="{{item}}"
              bindtap="previewImage"
            />
          </view>
        </scroll-view>
      </view>

      <view class="section-card">
        <view class="section-title">完成事项</view>
        <view class="tag-grid">
          <view class="tag-item active" wx:for="{{record.completedItems}}" wx:key="code">
            {{item.text}}
          </view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-title">宠物状态</view>
        <view class="status-pill">{{record.petStatusText}}</view>
      </view>

      <view class="section-card">
        <view class="section-title">服务备注</view>
        <view class="remark-text">{{record.remark || '暂无备注'}}</view>
      </view>

      <view class="section-card">
        <view class="section-title">服务时间轴</view>
        <view class="timeline-item">
          <view class="timeline-dot"></view>
          <view class="timeline-content">
            <view class="timeline-title">到达服务地址</view>
            <view class="timeline-time">{{record.arrivedAt || '未记录'}}</view>
          </view>
        </view>
        <view class="timeline-item">
          <view class="timeline-dot active"></view>
          <view class="timeline-content">
            <view class="timeline-title">提交服务记录</view>
            <view class="timeline-time">{{record.submittedAt || '未记录'}}</view>
          </view>
        </view>
      </view>

      <view class="page-bottom-space"></view>
    </block>
  </scroll-view>
</view>