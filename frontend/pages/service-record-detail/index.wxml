<view class="record-detail-page">
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-side nav-left" bindtap="navigateBack">‹</view>
      <view class="nav-title">服务记录详情</view>
      <view class="nav-side"></view>
    </view>
  </view>

  <scroll-view class="content" scroll-y style="height: calc(100vh - {{navTotalHeight}}px - 120rpx);">
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-text">加载中...</view>
    </view>

    <block wx:elif="{{detail}}">
      <!-- 顶部摘要 -->
      <view class="summary-card">
        <view class="summary-title">本次服务已提交</view>
        <view class="summary-time">提交时间：{{detail.submittedAtText}}</view>
      </view>

      <!-- 服务项目 -->
      <view class="section-card">
        <view class="section-title">服务项目</view>

        <view class="tag-grid" wx:if="{{detail.serviceItems.length}}">
          <view class="tag-item active" wx:for="{{detail.serviceItems}}" wx:key="code">
            {{item.text}}
          </view>
        </view>

        <view class="empty-text" wx:else>暂无服务项目</view>
      </view>

      <!-- 宠物观察情况 -->
      <view class="section-card">
        <view class="section-title">宠物观察情况</view>

        <view class="tag-grid" wx:if="{{detail.petObservations.length}}">
          <view
            class="tag-item {{item.isAbnormal ? 'warning' : 'active'}}"
            wx:for="{{detail.petObservations}}"
            wx:key="code"
          >
            {{item.text}}
          </view>
        </view>

        <view class="empty-text" wx:else>暂无观察情况</view>

        <view class="abnormal-box" wx:if="{{detail.hasAbnormal}}">
          <view class="abnormal-title">异常情况说明</view>
          <view class="abnormal-text">{{detail.abnormalDesc}}</view>
        </view>
      </view>

      <!-- 服务照片 -->
      <view class="section-card">
        <view class="section-title">服务照片</view>

        <view class="media-grid" wx:if="{{detail.hasImages}}">
          <image
            class="image-thumb"
            wx:for="{{detail.images}}"
            wx:key="url"
            src="{{item.url}}"
            mode="aspectFill"
            data-index="{{index}}"
            bindtap="previewImage"
          />
        </view>

        <view class="empty-text" wx:else>暂无服务照片</view>
      </view>

      <!-- 服务视频 -->
      <view class="section-card">
        <view class="section-title">服务视频</view>

        <view class="video-list" wx:if="{{detail.hasVideos}}">
          <view class="video-card" wx:for="{{detail.videos}}" wx:key="url">
            <video
              class="video-player"
              src="{{item.url}}"
              controls
              objectFit="cover"
            />
          </view>
        </view>

        <view class="empty-text" wx:else>暂无服务视频</view>
      </view>

      <!-- 服务备注 -->
      <view class="section-card">
        <view class="section-title">服务备注</view>
        <view class="remark-box">{{detail.remark}}</view>
      </view>

      <view class="page-bottom-space"></view>
    </block>
  </scroll-view>

  <view class="bottom-bar">
    <button class="ghost-btn action-btn" bindtap="handleContactService">联系客服</button>
  </view>
</view>