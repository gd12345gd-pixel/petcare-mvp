.record-detail-page {
  min-height: 100vh;
  background: #f7f8fb;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.custom-nav {
  background: #fff7fa;
  border-bottom: 1rpx solid #f2e6eb;
  box-sizing: border-box;
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.nav-side {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 52rpx;
  color: #111;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
}

.content {
  box-sizing: border-box;
}

.loading-wrap {
  padding: 240rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.summary-card,
.section-card {
  margin: 16rpx 16rpx 0;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 4rpx 14rpx rgba(31, 35, 41, 0.04);
  box-sizing: border-box;
}

.summary-card {
  background: linear-gradient(180deg, #fff1f5 0%, #fff8fa 100%);
}

.summary-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #ff5f8d;
  line-height: 1.3;
}

.summary-time {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.6;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
  line-height: 1.4;
}

.tag-grid {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-item {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.2;
  border: 1rpx solid transparent;
}

.tag-item.active {
  background: #fff1f5;
  color: #ff5f8d;
  border-color: #ffd6e2;
}

.tag-item.warning {
  background: #fff4e8;
  color: #ff8a00;
  border-color: #ffd7ae;
}

.abnormal-box {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #fff8f0;
  border: 1rpx solid #ffe2bf;
}

.abnormal-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #ff8a00;
  line-height: 1.4;
}

.abnormal-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7a4a16;
  line-height: 1.7;
}

.empty-text {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #9aa0aa;
  line-height: 1.6;
}

.media-grid {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.image-thumb {
  width: 210rpx;
  height: 210rpx;
  border-radius: 18rpx;
  background: #f3f4f6;
}

.video-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.video-card {
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 14rpx;
}

.video-player {
  width: 100%;
  height: 360rpx;
  border-radius: 14rpx;
  background: #000;
}

.remark-box {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f8f9fc;
  font-size: 26rpx;
  color: #222;
  line-height: 1.8;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 14rpx 20rpx calc(14rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 18rpx;
}

.ghost-btn {
  background: #fff;
  color: #666;
  border: 1rpx solid #eceef2;
}

.page-bottom-space {
  height: 32rpx;
}