.record-detail-page {
  min-height: 100vh;
  background: #f7f8fb;
}

.custom-nav {
  background: #fff7fa;
  border-bottom: 1rpx solid #f2e6eb;
  box-sizing: border-box;
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.nav-side {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 52rpx;
  color: #111;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
}

.content {
  box-sizing: border-box;
}

.loading-wrap {
  padding: 240rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.status-card,
.section-card {
  margin: 16rpx 16rpx 0;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 4rpx 14rpx rgba(31, 35, 41, 0.04);
  box-sizing: border-box;
}

.status-card {
  background: linear-gradient(180deg, #ffeef3 0%, #ffffff 100%);
}

.status-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #ff5f8d;
}

.status-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8b8f97;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
  margin-bottom: 18rpx;
}

.image-scroll {
  white-space: nowrap;
}

.image-row {
  display: inline-flex;
  gap: 16rpx;
}

.record-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 20rpx;
  background: #f2f2f2;
  flex-shrink: 0;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-item {
  min-width: 150rpx;
  height: 66rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #fff1f5;
  color: #ff5f8d;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.status-pill {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff1f5;
  color: #ff5f8d;
  font-size: 24rpx;
  line-height: 1.2;
}

.remark-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.7;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  position: relative;
}

.timeline-item + .timeline-item {
  margin-top: 24rpx;
}

.timeline-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #d9dde5;
  margin-top: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.timeline-dot.active {
  background: #ff5f8d;
}

.timeline-content {
  flex: 1;
}

.timeline-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #222;
}

.timeline-time {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #9aa0aa;
}

.page-bottom-space {
  height: 28rpx;
}