<view class="page-bg">
  <view class="nav-bar nav-bar-pink">
    <view class="back-area" bindtap="navigateBack">
      <view class="back-icon"></view>
    </view>
    <view class="nav-title">个人信息</view>
  </view>

  <view class="container">
    <view class="section-card form-card">
      <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" loading="{{uploading}}">
        <image wx:if="{{form.avatarUrl}}" class="avatar-image" src="{{form.avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">头像</view>
      </button>

      <view class="field">
        <view class="field-label">昵称</view>
        <input
          class="input"
          type="nickname"
          placeholder="请输入昵称"
          value="{{form.nickname}}"
          bindinput="onNicknameInput"
        />
      </view>

      <view class="field">
        <view class="field-label">手机号</view>
        <input
          class="input"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          value="{{form.phone}}"
          bindinput="onPhoneInput"
        />
      </view>
    </view>

    <button class="save-btn" bindtap="saveProfile" loading="{{saving}}">保存</button>
  </view>
</view>
