.container {
  padding: 20rpx 16rpx 40rpx;
  box-sizing: border-box;
}

.form-card {
  padding-top: 40rpx;
}

.avatar-picker {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0 auto 36rpx;
  background: #fff2f5;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-image {
  width: 140rpx;
  height: 140rpx;
}

.avatar-placeholder {
  color: #ff5f8d;
  font-size: 28rpx;
  font-weight: 800;
}

.field {
  margin-bottom: 26rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.save-btn {
  margin: 24rpx 16rpx 0;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ff6b81 0%, #ff5f8d 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
}
