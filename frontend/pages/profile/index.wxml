<view class="page-bg">
  <view class="container">
    <view class="hero-card">
      <view class="hero-bg hero-bg-1"></view>
      <view class="hero-bg hero-bg-2"></view>

      <view class="hero-top" bindtap="handleProfileTap">
        <image
          class="profile-avatar {{!isLoggedIn ? 'empty-avatar' : ''}}"
          src="{{isLoggedIn && currentUser.avatarUrl ? currentUser.avatarUrl : ''}}"
          mode="aspectFill"
        />
        <view class="profile-info">
          <view class="page-title" wx:if="{{isLoggedIn}}">{{currentUser.nickname || '微信用户'}}</view>
          <view class="page-title login-entry" wx:else bindtap="goLogin">登录/注册</view>
          <view class="desc-text profile-sub" wx:if="{{isLoggedIn}}">欢迎回来，今天也要照顾好毛孩子呀</view>
          <view class="desc-text profile-sub" wx:else>登录后可管理宠物、地址和订单</view>
        </view>
      </view>

      <view class="hero-stats">
        <view class="stat-item" bindtap="goMyPets">
          <view class="stat-num">{{stats.petCount}}</view>
          <view class="muted-text stat-label">宠物档案</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item" bindtap="goMyOrders">
          <view class="stat-num">{{stats.orderCount}}</view>
          <view class="muted-text stat-label">历史订单</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item" bindtap="goAddressList">
          <view class="stat-num">{{stats.addressCount}}</view>
          <view class="muted-text stat-label">常用地址</view>
        </view>
      </view>
    </view>

    <view class="section-card quick-card">
      <view class="section-head">
        <view class="menu-group-title">快捷入口</view>
        <view class="section-hint">常用功能</view>
      </view>

      <view class="quick-grid">
        <view class="quick-item notification-quick" bindtap="goNotifications">
          <view class="quick-icon notification"></view>
          <view class="quick-badge" wx:if="{{unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</view>
          <view class="quick-text">消息通知</view>
        </view>

        <view class="quick-item" bindtap="goMyPets">
          <view class="quick-icon pet"></view>
          <view class="quick-text">我的宠物</view>
        </view>

        <view class="quick-item" bindtap="goMyOrders">
          <view class="quick-icon order"></view>
          <view class="quick-text">我的订单</view>
        </view>

        <view class="quick-item" bindtap="goAddressList">
          <view class="quick-icon address"></view>
          <view class="quick-text">服务地址</view>
        </view>
      </view>
    </view>

    <view class="section-card menu-card">
      <view class="menu-group-title">账号服务</view>

      <view class="menu-item no-border" wx:if="{{isLoggedIn}}" bindtap="goEditProfile">
        <view class="menu-left">
          <view class="menu-icon profile-edit"></view>
          <view class="menu-text-wrap">
            <view class="block-title menu-text">个人信息</view>
            <view class="desc-text menu-desc">修改头像、昵称和手机号</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>
    </view>

    <view class="section-card menu-card">
      <view class="menu-group-title">接单师服务</view>

      <view class="menu-item" bindtap="goSitterRegister">
        <view class="menu-left">
          <view class="menu-icon sitter"></view>
          <view class="menu-text-wrap">
            <view class="block-title menu-text">成为托托师</view>
            <view class="desc-text menu-desc">申请接单师、查看审核和押金状态</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>

      <view class="menu-item" bindtap="goSitterWorkbench">
        <view class="menu-left">
          <view class="menu-icon workbench"></view>
          <view class="menu-text-wrap">
            <view class="block-title menu-text">托托师工作台</view>
            <view class="desc-text menu-desc">查看今日接单、服务安排和收益</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>

      <view class="menu-item no-border" wx:if="{{isAdmin}}" bindtap="goSitterAudit">
        <view class="menu-left">
          <view class="menu-icon audit"></view>
          <view class="menu-text-wrap">
            <view class="block-title menu-text">接单师审核</view>
            <view class="desc-text menu-desc">管理员审核入驻申请</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>
    </view>

    <view class="section-card menu-card">
      <view class="menu-group-title">帮助与支持</view>

      <view class="menu-item contact-menu-wrap">
        <view class="menu-left">
          <view class="menu-icon contact"></view>
          <view class="menu-text-wrap">
            <view class="block-title menu-text">联系客服</view>
            <view class="desc-text menu-desc">进入微信客服会话</view>
          </view>
        </view>
        <view class="arrow">›</view>
        <button class="contact-hit-button" open-type="contact" session-from="profile_menu"></button>
      </view>

      <view class="menu-item" bindtap="goFeedback">
        <view class="menu-left">
          <view class="menu-icon feedback"></view>
          <view class="menu-text-wrap">
            <view class="block-title menu-text">问题反馈</view>
            <view class="desc-text menu-desc">提交订单、服务或功能问题</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>

      <view class="menu-item" bindtap="goFaq">
        <view class="menu-left">
          <view class="menu-icon faq"></view>
          <view class="menu-text-wrap">
            <view class="block-title menu-text">常见问题</view>
            <view class="desc-text menu-desc">下单、服务、退款相关说明</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>

      <view class="menu-item no-border" bindtap="goAbout">
        <view class="menu-left">
          <view class="menu-icon about"></view>
          <view class="menu-text-wrap">
            <view class="block-title menu-text">关于我们</view>
            <view class="desc-text menu-desc">了解平台与服务介绍</view>
          </view>
        </view>
        <view class="arrow">›</view>
      </view>
    </view>

    <button wx:if="{{isLoggedIn}}" class="logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>
