.success-page {
  min-height: 100vh;
  background: #f7f8fb;
}

.custom-nav {
  background: #fff7fa;
  border-bottom: 1rpx solid #f2e6eb;
  box-sizing: border-box;
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.nav-side {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
}

.success-content {
  padding: 140rpx 40rpx 0;
  text-align: center;
}

.success-icon-wrap {
  display: flex;
  justify-content: center;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #ffedf2;
  color: #ff5f8d;
  font-size: 64rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-title {
  margin-top: 28rpx;
  font-size: 38rpx;
  font-weight: 800;
  color: #222;
}

.success-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.6;
}

.success-actions {
  margin-top: 54rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 18rpx;
}