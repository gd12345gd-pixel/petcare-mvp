.page {
  min-height: 100vh;
  background: #f6f7fb;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.nav-bar {
  height: 96rpx;
  display: flex;
  align-items: center;
  position: relative;
  padding: 0 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.back-area {
  width: 64rpx;
  font-size: 36rpx;
  color: #222;
}

.nav-title {
  position: absolute;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
}

.content {
  height: calc(100vh - 96rpx - 120rpx);
}

.address-list {
  padding: 20rpx;
}

.address-card {
  background: #fff;
  border-radius: 22rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.address-card.active {
  border-color: #ff9ab0;
  background: #fff8fa;
}

.address-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.name-phone {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 14rpx;
}

.contact-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
}

.contact-phone {
  font-size: 24rpx;
  color: #666;
}

.right-tags {
  display: flex;
  gap: 10rpx;
}

.default-tag,
.custom-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.2;
}

.default-tag {
  background: #ffedf2;
  color: #ff5f8d;
}

.custom-tag {
  background: #f3f4f6;
  color: #666;
}

.address-text {
  margin-top: 16rpx;
  font-size: 25rpx;
  color: #333;
  line-height: 1.6;
}

.address-actions {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.action-left,
.action-right {
  display: flex;
  gap: 14rpx;
}

.small-btn {
  font-size: 22rpx;
  color: #666;
  padding: 8rpx 0;
}

.small-btn.danger {
  color: #ff6b81;
}

.empty-wrap {
  padding-top: 180rpx;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #9aa0aa;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0.96);
  padding: 16rpx 20rpx 24rpx;
  box-sizing: border-box;
  border-top: 1rpx solid #f0f0f0;
}

.add-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #ff9200 0%, #ff7a00 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
}