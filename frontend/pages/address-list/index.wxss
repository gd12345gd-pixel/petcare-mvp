.content {
  height: calc(100vh - 96rpx - 156rpx);
}

.address-list {
  padding: 20rpx 16rpx 0;
}

.address-card {
  background: #fff;
  border-radius: 22rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  box-shadow: 0 4rpx 14rpx rgba(31, 35, 41, 0.04);
}

.address-card.active {
  border-color: #ff9ab0;
  background: #fff8fa;
}

.address-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.name-phone {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 14rpx;
}

.contact-name {
  line-height: 1.3;
}

.contact-phone {
  line-height: 1.4;
}

.right-tags {
  display: flex;
  gap: 10rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.address-text {
  margin-top: 16rpx;
  line-height: 1.6;
}

.address-actions {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.action-left,
.action-right {
  display: flex;
  gap: 14rpx;
}

.small-btn {
  font-size: 22rpx;
  color: #666;
  padding: 8rpx 0;
  line-height: 1.4;
}

.small-btn.danger {
  color: #ff6b81;
}

.empty-btn {
  margin: 28rpx auto 0;
  width: 240rpx;
}

.add-btn {
  width: 100%;
}