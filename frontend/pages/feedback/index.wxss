.container {
  padding: 20rpx 16rpx 40rpx;
  box-sizing: border-box;
}

.hero-card,
.form-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(31, 35, 41, 0.05);
  box-sizing: border-box;
}

.hero-card {
  background: linear-gradient(180deg, #ffeef4 0%, #fff7fa 100%);
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #222;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 25rpx;
  color: #777;
  line-height: 1.6;
}

.field-label {
  margin: 22rpx 0 12rpx;
  font-size: 26rpx;
  color: #333;
  font-weight: 700;
}

.picker-value,
.input,
.textarea {
  width: 100%;
  background: #f8f8fb;
  border-radius: 18rpx;
  padding: 22rpx 20rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #333;
}

.textarea {
  height: 240rpx;
}

.submit-btn,
.contact-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.submit-btn {
  background: linear-gradient(90deg, #ff7a9a 0%, #ff5a7a 100%);
  color: #fff;
}

.contact-btn {
  margin-top: 18rpx;
  background: #fff;
  color: #ff5a7a;
  border: 1rpx solid #ffd1dd;
}

.contact-btn::after {
  border: none;
}
