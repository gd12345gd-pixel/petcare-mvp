.page {
  min-height: 100vh;
  background: #fdf1f5;
  padding: 24rpx;
  box-sizing: border-box;
}

.publish-hero {
  margin-bottom: 20rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ff7993 0%, #ffeff4 100%);
  color: #fff;
}

.publish-title {
  font-size: 38rpx;
  font-weight: 900;
}

.publish-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.92);
}

.top-switch {
  display: flex;
  background: #fff;
  border-radius: 999rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.switch-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  padding: 18rpx 0;
  border-radius: 999rpx;
}

.switch-item.active {
  background: #fff1f4;
  color: #ff6b81;
  font-weight: 700;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.mt {
  margin-top: 24rpx;
}

.upload-box {
  height: 260rpx;
  border: 2rpx dashed #f3a2b3;
  background: #fff8fa;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  position: relative;
  width: 58rpx;
  height: 46rpx;
  margin-bottom: 10rpx;
  border: 5rpx solid #ff9aae;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.upload-icon::before {
  content: '';
  position: absolute;
  left: 17rpx;
  top: 12rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff9aae;
}

.upload-icon::after {
  content: '';
  position: absolute;
  left: 12rpx;
  top: -12rpx;
  width: 24rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #ff9aae;
}

.upload-text {
  font-size: 28rpx;
  color: #666;
}

.upload-sub {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 8rpx;
}

.preview-img {
  width: 100%;
  height: 280rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
}

.input {
  height: 84rpx;
  background: #f8f8f8;
  border-radius: 18rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.picker-input {
  display: flex;
  align-items: center;
  box-sizing: border-box;
  color: #333;
}

.picker-input.placeholder {
  color: #aaa;
}

.time-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.location-box {
  height: 84rpx;
  background: #f8f8f8;
  border-radius: 18rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
}

.location-placeholder {
  color: #aaa;
  font-size: 28rpx;
}

.location-text {
  color: #333;
  font-size: 28rpx;
}

.region-display {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #ff6b81;
  line-height: 1.6;
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  background: #f8f8f8;
  border-radius: 18rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.checkbox-row {
  display: flex;
  align-items: center;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border-radius: 8rpx;
  border: 2rpx solid #ff6b81;
  margin-right: 12rpx;
  box-sizing: border-box;
}

.checkbox.checked {
  background: #ff6b81;
}

.checkbox-text {
  font-size: 26rpx;
  color: #555;
}

.agree-wrap {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
}

.agree-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #ff6b81;
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10rpx;
}

.agree-text {
  font-size: 24rpx;
  color: #777;
}

.submit-btn {
  margin-top: 28rpx;
  background: #ff6b81;
  color: #fff;
  border-radius: 999rpx;
  font-size: 30rpx;
}