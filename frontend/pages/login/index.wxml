<view class="page">
  <view class="card" wx:if="{{step === 'login'}}">
    <view class="title">欢迎使用宠物上门服务</view>
    <view class="desc">先通过微信创建/登录账号，之后可预约、查看订单和管理宠物档案。</view>

    <button class="login-btn" bindtap="handleWechatLogin" loading="{{loading}}">
      微信快捷登录
    </button>

    <button class="guest-btn" bindtap="goGuest">
      先逛逛
    </button>
  </view>

  <view class="card" wx:else>
    <view class="title">完善资料</view>
    <view class="desc">补充头像、昵称和手机号，方便托托师服务前与你确认信息。</view>

    <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" loading="{{uploading}}">
      <image wx:if="{{profileForm.avatarUrl}}" class="avatar-image" src="{{profileForm.avatarUrl}}" mode="aspectFill" />
      <view wx:else class="avatar-placeholder">头像</view>
    </button>

    <view class="field">
      <view class="field-label">昵称</view>
      <input
        class="input"
        type="nickname"
        placeholder="请输入昵称"
        value="{{profileForm.nickname}}"
        bindinput="onNicknameInput"
      />
    </view>

    <view class="field">
      <view class="field-label">手机号</view>
      <input
        class="input"
        type="number"
        maxlength="11"
        placeholder="用于服务前联系，可稍后填写"
        value="{{profileForm.phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <button class="login-btn" bindtap="saveProfile" loading="{{saving}}">
      保存并继续
    </button>

    <button class="guest-btn" bindtap="skipProfile">
      稍后再补充
    </button>
  </view>
</view>
