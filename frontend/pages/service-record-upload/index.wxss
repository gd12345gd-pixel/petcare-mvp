.record-upload-page {
  min-height: 100vh;
  background: #f7f8fb;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.custom-nav {
  background: #fff7fa;
  border-bottom: 1rpx solid #f2e6eb;
  box-sizing: border-box;
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.nav-side {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 52rpx;
  color: #111;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
}

.content {
  box-sizing: border-box;
}

.loading-wrap {
  padding: 240rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.section-card {
  margin: 16rpx 16rpx 0;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 4rpx 14rpx rgba(31, 35, 41, 0.04);
  box-sizing: border-box;
}

.subtle-card {
  background: #fcfcfd;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
  line-height: 1.4;
}

.section-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9aa0aa;
  line-height: 1.6;
}

.required-desc,
.required-title {
  color: #ff5f8d;
}

.info-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
}

.info-label {
  width: 140rpx;
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.5;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #222;
  font-weight: 700;
  line-height: 1.6;
  word-break: break-all;
}

.tag-grid {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-item {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #f7f8fb;
  color: #666;
  font-size: 24rpx;
  line-height: 1.2;
  border: 1rpx solid #eceef2;
}

.tag-item.active {
  background: #fff1f5;
  color: #ff5f8d;
  border-color: #ffd6e2;
}

.sub-section {
  margin-top: 22rpx;
}

.sub-title {
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  background: #f7f8fb;
  border-radius: 18rpx;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #222;
  border: 1rpx solid #edf0f4;
  line-height: 1.6;
}

.media-grid {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.image-item,
.video-item,
.upload-box {
  width: 210rpx;
  height: 210rpx;
  border-radius: 18rpx;
  overflow: hidden;
  position: relative;
  box-sizing: border-box;
}

.image-item,
.video-item {
  background: #f3f4f6;
}

.image-thumb,
.video-thumb {
  width: 100%;
  height: 100%;
}

.delete-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 28rpx;
  line-height: 42rpx;
  text-align: center;
  z-index: 3;
}

.upload-box {
  background: #f7f8fb;
  border: 1rpx dashed #d8dde6;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-plus {
  font-size: 44rpx;
  color: #c0c6d0;
  line-height: 1;
}

.upload-text {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9aa0aa;
  line-height: 1.3;
}

.exception-entry {
  padding: 6rpx 0;
}

.exception-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.4;
}

.exception-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #9aa0aa;
  line-height: 1.6;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 14rpx 20rpx calc(14rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 18rpx;
}

.page-bottom-space {
  height: 32rpx;
}