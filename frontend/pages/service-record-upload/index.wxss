.service-record-page {
  min-height: 100vh;
  background: #f7f8fb;
  padding-bottom: 190rpx;
  box-sizing: border-box;
}

.custom-nav {
  background: #fff7fa;
  border-bottom: 1rpx solid #f2e6eb;
  box-sizing: border-box;
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.nav-side {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 52rpx;
  color: #111;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
}

.content {
  box-sizing: border-box;
}

.loading-wrap {
  padding: 240rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.section-card {
  margin: 16rpx 16rpx 0;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 4rpx 14rpx rgba(31, 35, 41, 0.04);
  box-sizing: border-box;
}

.top-card {
  background: linear-gradient(180deg, #ffeef3 0%, #ffffff 100%);
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
  margin-bottom: 18rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.info-row + .info-row {
  margin-top: 16rpx;
}

.info-label {
  font-size: 24rpx;
  color: #8b8f97;
}

.info-value {
  font-size: 26rpx;
  color: #222;
  font-weight: 700;
  text-align: right;
}

.address-value {
  max-width: 430rpx;
  line-height: 1.5;
}

.upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item,
.upload-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
}

.upload-image {
  width: 100%;
  height: 100%;
  background: #f2f2f2;
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-add {
  border: 2rpx dashed #d9dde5;
  background: #fafbfc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-add-icon {
  font-size: 48rpx;
  color: #aab1bc;
  line-height: 1;
}

.upload-add-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8b8f97;
}

.field-tip {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #9aa0aa;
  line-height: 1.6;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-item {
  min-width: 150rpx;
  height: 66rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  border: 2rpx solid #eceef2;
  background: #fff;
  color: #666;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.tag-item.active {
  border-color: #ff6b81;
  background: #fff1f5;
  color: #ff5f8d;
}

.status-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.status-item {
  height: 78rpx;
  border-radius: 18rpx;
  background: #f8f9fc;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
}

.status-item.active {
  background: #fff1f5;
}

.status-radio {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  border: 2rpx solid #cfd5de;
  box-sizing: border-box;
  margin-right: 14rpx;
  background: #fff;
}

.status-radio.active {
  border-color: #ff5f8d;
  background: radial-gradient(circle, #ff5f8d 45%, #fff 46%);
}

.status-text {
  font-size: 26rpx;
  color: #222;
}

.remark-textarea {
  width: 100%;
  min-height: 220rpx;
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #222;
  line-height: 1.7;
}

.remark-count {
  margin-top: 10rpx;
  text-align: right;
  font-size: 22rpx;
  color: #b3b7c0;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  padding: 14rpx 20rpx calc(14rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 18rpx;
}

.page-bottom-space {
  height: 28rpx;
}