.page {
  min-height: 100vh;
  background: #fdf1f5;
  padding: 24rpx;
  box-sizing: border-box;
}

.order-card,
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.info {
  font-size: 24rpx;
  color: #777;
  line-height: 1.8;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #ff6b81;
  margin-bottom: 20rpx;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.type-item {
  height: 88rpx;
  border-radius: 20rpx;
  background: #f8f8f8;
  color: #555;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
}

.type-item.active {
  background: #fff2f5;
  color: #ff6b81;
  border-color: #ff6b81;
}

.label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.mt {
  margin-top: 24rpx;
}

.upload-box {
  height: 220rpx;
  border: 2rpx dashed #f3a2b3;
  border-radius: 20rpx;
  background: #fff8fa;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.upload-text {
  font-size: 26rpx;
  color: #999;
}

.image-preview {
  display: flex;
  flex-direction: column;
}

.preview-img {
  width: 100%;
  height: 320rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
}

.img-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.input {
  height: 82rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.textarea {
  width: 100%;
  min-height: 180rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.btn-card button {
  margin-bottom: 20rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.start-btn {
  background: #ffb347;
  color: #fff;
}

.submit-btn {
  background: #ff6b81;
  color: #fff;
}
.uploading-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #ff6b81;
}
.video-box {
  background: #faf7ff;
  border-color: #c8b5f5;
}

.video-preview {
  display: flex;
  flex-direction: column;
}

.preview-video {
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
  background: #000;
}
.finish-btn {
  background: #8a63d2;
  color: #fff;
}