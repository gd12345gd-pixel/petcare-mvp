<view class="service-record-page">
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-side nav-left" bindtap="navigateBack">‹</view>
      <view class="nav-title">填写服务记录</view>
      <view class="nav-side"></view>
    </view>
  </view>

  <scroll-view class="content" scroll-y style="height: calc(100vh - {{navTotalHeight}}px - 170rpx);">
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-text">加载中...</view>
    </view>

    <block wx:elif="{{order}}">
      <view class="section-card top-card">
        <view class="section-title">本次服务</view>
        <view class="info-row">
          <text class="info-label">服务日期</text>
          <text class="info-value">{{order.scheduleDateText}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">服务时间</text>
          <text class="info-value">{{order.scheduleTimeText}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">服务时长</text>
          <text class="info-value">{{order.scheduleDurationText}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">服务地址</text>
          <text class="info-value address-value">{{order.fullAddress}}</text>
        </view>
      </view>

      <view class="section-card">
        <view class="section-title">服务照片</view>
        <view class="upload-grid">
          <view class="image-item" wx:for="{{imageUrls}}" wx:key="*this">
            <image class="upload-image" src="{{item}}" mode="aspectFill" data-url="{{item}}" bindtap="previewImage" />
            <view class="remove-btn" data-index="{{index}}" bindtap="removeImage">×</view>
          </view>

          <view class="upload-add" wx:if="{{imageUrls.length < 6}}" bindtap="chooseImages">
            <view class="upload-add-icon">+</view>
            <view class="upload-add-text">上传图片</view>
          </view>
        </view>
        <view class="field-tip">最多上传6张，建议拍摄喂食、清理、宠物状态等照片</view>
      </view>

      <view class="section-card">
        <view class="section-title">完成事项</view>
        <view class="tag-grid">
          <view
            class="tag-item {{item.checked ? 'active' : ''}}"
            wx:for="{{completedOptions}}"
            wx:key="value"
            data-value="{{item.value}}"
            bindtap="toggleCompletedItem"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-title">宠物状态</view>
        <view class="status-list">
          <view
            class="status-item {{item.checked ? 'active' : ''}}"
            wx:for="{{petStatusOptions}}"
            wx:key="value"
            data-value="{{item.value}}"
            bindtap="choosePetStatus"
          >
            <view class="status-radio {{item.checked ? 'active' : ''}}"></view>
            <view class="status-text">{{item.label}}</view>
          </view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-title">服务备注</view>
        <textarea
          class="remark-textarea"
          placeholder="请填写本次服务情况，如进食、饮水、情绪、清理情况等"
          value="{{remark}}"
          bindinput="onRemarkInput"
          maxlength="300"
        ></textarea>
        <view class="remark-count">{{remark.length}}/300</view>
      </view>

      <view class="page-bottom-space"></view>
    </block>
  </scroll-view>

  <view class="bottom-bar" wx:if="{{!loading && order}}">
    <button class="primary-btn submit-btn" bindtap="submitRecord" loading="{{submitting}}">
      提交服务记录
    </button>
  </view>
</view>