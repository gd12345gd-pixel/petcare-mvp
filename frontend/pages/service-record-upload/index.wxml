<view class="record-upload-page">
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-side nav-left" bindtap="navigateBack">‹</view>
      <view class="nav-title">提交服务记录</view>
      <view class="nav-side"></view>
    </view>
  </view>

  <scroll-view class="content" scroll-y style="height: calc(100vh - {{navTotalHeight}}px - 140rpx);">
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-text">加载中...</view>
    </view>

    <block wx:elif="{{!loading}}">
      <!-- 本次服务信息 -->
      <view class="section-card">
        <view class="section-title">本次服务信息</view>

        <view class="info-row">
          <view class="info-label">服务日期</view>
          <view class="info-value">{{baseInfo.serviceDateText}}</view>
        </view>

        <view class="info-row">
          <view class="info-label">服务时间</view>
          <view class="info-value">{{baseInfo.timeSlotsText}}</view>
        </view>

        <view class="info-row">
          <view class="info-label">服务宠物</view>
          <view class="info-value">{{baseInfo.petsText}}</view>
        </view>

        <view class="info-row">
          <view class="info-label">服务地址</view>
          <view class="info-value">{{baseInfo.addressText}}</view>
        </view>
      </view>

      <!-- 服务项目 -->
      <view class="section-card">
        <view class="section-title">服务项目</view>
        <view class="section-desc">请至少选择 1 项</view>

        <view class="tag-grid">
          <view
            class="tag-item {{item.checked ? 'active' : ''}}"
            wx:for="{{serviceItemOptions}}"
            wx:key="key"
            data-key="{{item.key}}"
            bindtap="toggleServiceItem"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <!-- 宠物观察情况 -->
      <view class="section-card">
        <view class="section-title">宠物观察情况</view>
        <view class="section-desc">可多选，若有异常请补充说明</view>

        <view class="tag-grid">
          <view
            class="tag-item {{item.checked ? 'active' : ''}}"
            wx:for="{{petObservationOptions}}"
            wx:key="key"
            data-key="{{item.key}}"
            bindtap="toggleObservationItem"
          >
            {{item.label}}
          </view>
        </view>

        <view class="sub-section" wx:if="{{hasAbnormalSelected()}}">
          <view class="sub-title required-title">异常情况</view>
          <textarea
            class="textarea"
            value="{{abnormalDesc}}"
            placeholder="请填写异常情况，例如宠物精神不佳、进食异常、发现不适等"
            maxlength="300"
            bindinput="onInputAbnormalDesc"
          />
        </view>
      </view>

      <!-- 服务照片 -->
      <view class="section-card">
        <view class="section-title">服务照片</view>
        <view class="section-desc">建议上传现场照片，最多 9 张</view>

        <view class="media-grid">
          <view class="image-item" wx:for="{{imageList}}" wx:key="url">
            <image
              class="image-thumb"
              src="{{item.url}}"
              mode="aspectFill"
              data-index="{{index}}"
              bindtap="previewImage"
            />
            <view class="delete-badge" data-index="{{index}}" bindtap="removeImage">×</view>
          </view>

          <view class="upload-box" wx:if="{{imageList.length < 9}}" bindtap="chooseImages">
            <view class="upload-plus">＋</view>
            <view class="upload-text">上传图片</view>
          </view>
        </view>
      </view>

      <!-- 服务视频 -->
      <view class="section-card">
        <view class="section-title">服务视频</view>
        <view class="section-desc required-desc">至少上传 1 个，最多 3 个</view>

        <view class="media-grid">
          <view class="video-item" wx:for="{{videoList}}" wx:key="url">
            <video
              class="video-thumb"
              src="{{item.url}}"
              controls
              objectFit="cover"
            />
            <view class="delete-badge" data-index="{{index}}" bindtap="removeVideo">×</view>
          </view>

          <view class="upload-box" wx:if="{{videoList.length < 3}}" bindtap="chooseVideos">
            <view class="upload-plus">＋</view>
            <view class="upload-text">上传视频</view>
          </view>
        </view>
      </view>

      <!-- 服务备注 -->
      <view class="section-card">
        <view class="section-title">服务备注</view>
        <view class="section-desc">可补充本次服务细节，例如进食、情绪、排泄、陪伴等情况</view>

        <textarea
          class="textarea"
          value="{{remark}}"
          placeholder="请填写本次服务备注"
          maxlength="500"
          bindinput="onInputRemark"
        />
      </view>

      <!-- 异常入口 -->
      <view class="section-card subtle-card">
        <view class="exception-entry" bindtap="goReportException">
          <view class="exception-title">上报异常</view>
          <view class="exception-desc">若服务中遇到其他问题，可在这里上报异常情况</view>
        </view>
      </view>

      <view class="page-bottom-space"></view>
    </block>
  </scroll-view>

  <view class="bottom-bar">
    <button
      class="primary-btn submit-btn"
      loading="{{submitting}}"
      disabled="{{submitting}}"
      bindtap="submitRecord"
    >
      提交服务记录
    </button>
  </view>
</view>