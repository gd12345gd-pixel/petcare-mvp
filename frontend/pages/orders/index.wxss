.order-card{padding:24rpx;margin-bottom:24rpx}.order-top,.order-bottom{display:flex;justify-content:space-between;align-items:center}.order-no{font-size:24rpx;color:#666}.status{color:#ff5a7a;font-weight:700}.order-line{margin-top:14rpx}.order-price{color:#ff5a7a;font-size:36rpx;font-weight:700}.ghost-btn{background:#ffeff3;color:#ff5a7a;border-radius:999rpx;padding:14rpx 28rpx}.empty{text-align:center;padding:200rpx 0;color:#999}.popup-mask{position:fixed;inset:0;background:rgba(0,0,0,.4)}.popup{position:absolute;left:24rpx;right:24rpx;top:15%;max-height:70%;overflow:auto;padding:24rpx}.popup-item{margin-bottom:20rpx}.popup-img{width:100%;height:300rpx;border-radius:18rpx}.popup-text{margin-top:10rpx}