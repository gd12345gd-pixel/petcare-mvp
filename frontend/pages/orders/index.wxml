<view class="container">
  <block wx:for="{{orders}}" wx:key="id">
    <view class="card order-card">
      <view class="order-top">
        <view class="order-no">订单号：{{item.orderNo}}</view>
        <view class="status">{{statusTextMap[item.status]}}</view>
      </view>
      <view class="order-line">服务时间：{{item.serviceDate}} {{item.timeSlot}}</view>
      <view class="order-line">服务地址：{{item.address}}</view>
      <view class="order-bottom">
        <view class="order-price">¥{{item.amount}}</view>
        <button class="record-btn" data-item="{{item}}" bindtap="goRecordDetail">服务记录</button>
      </view>
    </view>
  </block>
  <view wx:if="{{orders.length === 0}}" class="empty">暂无订单</view>
  <view wx:if="{{recordPopup}}" class="popup-mask" bindtap="closePopup">
    <view class="popup card" catchtap="noop">
      <button class="record-btn" data-item="{{item}}" bindtap="goRecordDetail">服务记录</button>
      <block wx:for="{{records}}" wx:key="id">
        <view class="popup-item">
          <image class="popup-img" src="{{item.thumbnailUrl || item.mediaUrl}}" mode="aspectFill" />
          <view class="popup-text">{{item.content}}</view>
        </view>
      </block>
    </view>
  </view>
</view>