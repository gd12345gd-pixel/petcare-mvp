.top-card,.block{padding:24rpx;margin-bottom:24rpx}.top-row{display:flex;justify-content:space-between}.name{font-size:38rpx;font-weight:700}.price{color:#ff5a7a;font-size:44rpx;margin-top:12rpx;font-weight:700}.desc{margin-top:16rpx;color:#666;font-size:26rpx}.record-row{display:flex}.media-card{width:220rpx;margin-right:20rpx}.media-img{width:220rpx;height:180rpx;border-radius:18rpx}.media-text{margin-top:12rpx;font-size:24rpx}.content-grid{display:grid;grid-template-columns:1fr 1fr;gap:18rpx}.content-item{background:#fff6f8;border-radius:18rpx;padding:24rpx}.flow{display:flex;align-items:center;justify-content:space-between}.flow-step{width:120rpx;text-align:center;font-size:22rpx}.num{display:block;width:48rpx;height:48rpx;line-height:48rpx;text-align:center;color:#fff;background:#ff5a7a;border-radius:999rpx;margin:0 auto 12rpx auto}.line{flex:1;height:4rpx;background:#ffd2db}.review{padding:18rpx 0;border-bottom:1rpx solid #f3f3f3}.review-content{margin-top:10rpx;color:#666}.bottom-bar{position:fixed;left:0;right:0;bottom:0;background:#fff;padding:20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));display:flex;align-items:center;box-shadow:0 -8rpx 24rpx rgba(0,0,0,.05)}.bottom-price{flex:1;font-size:34rpx;color:#ff5a7a;font-weight:700}.bottom-btn{width:260rpx;text-align:center;background:linear-gradient(90deg,#ff6b81,#ff4d6d);color:#fff;border-radius:44rpx;padding:22rpx 0}