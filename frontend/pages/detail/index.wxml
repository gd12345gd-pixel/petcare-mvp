<view class="container" wx:if="{{service}}">
  <view class="card top-card">
    <view class="top-row">
      <view>
        <view class="name">{{service.name}}</view>
        <view class="price">¥{{service.price}} / {{service.unitLabel}}</view>
      </view>
      <view><text class="tag">热门服务</text><text class="tag">含视频记录</text></view>
    </view>
    <view class="desc">{{service.description}}</view>
  </view>
  <view class="card block">
    <view class="section-title">服务过程展示</view>
    <scroll-view scroll-x="true" enable-flex="true">
      <view class="record-row">
        <block wx:for="{{records}}" wx:key="id">
          <view class="media-card">
            <image class="media-img" src="{{item.thumbnailUrl || item.mediaUrl}}" mode="aspectFill" />
            <view class="media-text">{{item.content}}</view>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>
  <view class="card block">
    <view class="section-title">服务内容</view>
    <view class="content-grid">
      <view class="content-item">🍽️ 喂食</view>
      <view class="content-item">💧 换水</view>
      <view class="content-item">🧹 清理猫砂</view>
      <view class="content-item">🐾 简单互动</view>
    </view>
  </view>
  <view class="card block">
    <view class="section-title">服务流程</view>
    <view class="flow">
      <view class="flow-step"><text class="num">1</text><text>下单</text></view>
      <view class="line"></view>
      <view class="flow-step"><text class="num">2</text><text>分配服务者</text></view>
      <view class="line"></view>
      <view class="flow-step"><text class="num">3</text><text>上门服务</text></view>
      <view class="line"></view>
      <view class="flow-step"><text class="num">4</text><text>上传视频</text></view>
    </view>
  </view>
  <view class="card block">
    <view class="section-title">用户评价</view>
    <block wx:for="{{reviews}}" wx:key="id">
      <view class="review">
        <view class="review-rating">⭐ {{item.rating}}.0</view>
        <view class="review-content">{{item.content}}</view>
      </view>
    </block>
  </view>
  <view class="bottom-bar">
    <view class="bottom-price">¥{{service.price}} / {{service.unitLabel}}</view>
    <view class="bottom-btn" bindtap="goOrder">立即预约</view>
  </view>
  <button bindtap="goTestUpload">测试上传服务记录</button>
</view>