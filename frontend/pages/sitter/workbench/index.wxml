<view class="workbench-page">
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-side nav-left" bindtap="navigateBack">
        <view class="nav-back-icon"></view>
      </view>
      <view class="nav-title">托托师工作台</view>
      <view class="nav-side"></view>
    </view>
  </view>

  <scroll-view class="content" scroll-y style="height: calc(100vh - {{navTotalHeight}}px);">
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-text">加载中...</view>
    </view>

    <block wx:elif="{{profile && profile.canAcceptOrder}}">
      <view class="profile-card">
        <image class="avatar" src="{{currentUser.avatarUrl || ''}}" mode="aspectFill" />
        <view class="profile-main">
          <view class="name-row">
            <view class="name">{{profile.realName || currentUser.nickname || '托托师'}}</view>
            <view class="verified-tag">已实名</view>
          </view>
          <view class="level-line">{{profile.levelCode || 'L0'}} {{profile.levelName || '新手托托师'}}</view>
          <view class="service-line">已服务 {{profile.completedOrders || 0}} 次 · 好评率 100%</view>
        </view>
        <view class="edit-chip" bindtap="goRegister">编辑名片 ›</view>
      </view>

      <view class="notice-card">
        <view class="notice-icon">✓</view>
        <view class="notice-text">身份已审核通过，押金已缴纳，可正常接单</view>
      </view>

      <view class="two-col">
        <view class="section-card action-card">
          <view class="card-title pink">今日接单情况</view>
          <view class="today-stats">
            <view class="today-stat">
              <view class="today-num">{{stats.todayAvailableCount}}</view>
              <view class="today-label">今日可接</view>
            </view>
            <view class="today-stat">
              <view class="today-num">{{stats.todayAcceptedCount}}</view>
              <view class="today-label">今日已接</view>
            </view>
          </view>
          <view class="nearby-text">附近可接订单 {{stats.nearbyAvailableCount}} 单</view>
          <button class="primary-btn compact-btn" bindtap="goTakeOrders">去接单</button>
        </view>

        <view class="section-card action-card">
          <view class="card-title blue">今日服务安排</view>
          <block wx:if="{{nextService}}">
            <view class="service-time">{{nextService.dateText}} {{nextService.timeText}}</view>
            <view class="service-desc">{{nextService.petText}} · {{nextService.addressText}}</view>
            <button class="secondary-btn compact-btn" bindtap="goServiceDetail">查看服务详情</button>
          </block>
          <block wx:else>
            <view class="empty-service">暂无待服务订单</view>
            <button class="secondary-btn compact-btn" bindtap="goTakeOrders">查看可接订单</button>
          </block>
        </view>
      </view>

      <view class="section-card">
        <view class="section-head">
          <view class="card-title">钱包收益</view>
          <view class="section-link">查看明细 ›</view>
        </view>
        <view class="income-grid">
          <view class="income-item">
            <view class="income-label">可提现(元)</view>
            <view class="income-value pink-text">{{income.withdrawable}}</view>
          </view>
          <view class="income-item">
            <view class="income-label">待结算(元)</view>
            <view class="income-value">{{income.pending}}</view>
          </view>
          <view class="income-item no-border">
            <view class="income-label">累计收入(元)</view>
            <view class="income-value">{{income.total}}</view>
          </view>
        </view>
      </view>

      <view class="two-col">
        <view class="section-card small-card">
          <view class="card-title">等级与信誉</view>
          <view class="level-main">{{profile.levelCode || 'L0'}} {{profile.levelName || '新手托托师'}}</view>
          <view class="progress-line">
            <view class="progress-bar" style="width: {{profile.completedOrders >= 2 ? 100 : (profile.completedOrders || 0) * 50}}%;"></view>
          </view>
          <view class="small-desc">再完成 {{profile.completedOrders >= 2 ? 0 : 2 - (profile.completedOrders || 0)}} 单可升级</view>
        </view>
        <view class="section-card small-card">
          <view class="card-title">信誉分</view>
          <view class="credit-score">{{profile.creditScore || 100}}</view>
          <view class="credit-tag">优秀</view>
          <view class="small-desc">等级规则 ›　信誉分规则 ›</view>
        </view>
      </view>

      <view class="section-card deposit-card">
        <view class="card-title">押金状态</view>
        <view class="deposit-main">已缴纳押金 ¥{{profile.depositAmount || 99}}</view>
        <view class="small-desc">当前无未完成订单时，可申请退还</view>
      </view>

      <view class="section-card">
        <view class="section-head">
          <view class="card-title">我的服务日历</view>
          <view class="section-link">查看全部安排 ›</view>
        </view>
        <view class="calendar-row">
          <view class="calendar-day {{item.active ? 'active' : ''}}" wx:for="{{calendarDays}}" wx:key="key">
            <view class="week">{{item.week}}</view>
            <view class="day">{{item.day}}</view>
            <view class="dot {{item.hasService ? 'has' : ''}}"></view>
          </view>
        </view>
        <view class="calendar-legend">
          <view><text class="legend-dot has"></text>有服务</view>
          <view><text class="legend-dot"></text>无服务</view>
        </view>
      </view>

      <view class="section-card">
        <view class="card-title">常用功能</view>
        <view class="feature-grid">
          <view class="feature-item" data-key="orders" bindtap="goFeature">
            <view class="feature-icon record"></view>
            <view class="feature-text">服务记录</view>
          </view>
          <view class="feature-item" data-key="income" bindtap="goFeature">
            <view class="feature-icon income"></view>
            <view class="feature-text">收入明细</view>
          </view>
          <view class="feature-item" data-key="comment" bindtap="goFeature">
            <view class="feature-icon comment"></view>
            <view class="feature-text">评价管理</view>
          </view>
          <view class="feature-item" data-key="rules" bindtap="goFeature">
            <view class="feature-icon rules"></view>
            <view class="feature-text">规则说明</view>
          </view>
        </view>
      </view>
    </block>

    <view class="state-card" wx:else>
      <view class="state-title">还不能进入工作台</view>
      <view class="state-desc">完成申请、审核和押金缴纳后，即可使用托托师工作台。</view>
      <button class="primary-btn state-btn" bindtap="goRegister">查看入驻状态</button>
    </view>

    <view class="page-bottom-space"></view>
  </scroll-view>
</view>
