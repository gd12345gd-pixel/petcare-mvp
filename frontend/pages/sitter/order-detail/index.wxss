.sitter-detail-page {
  min-height: 100vh;
  background: #f7f8fb;
  padding-bottom: 190rpx;
  box-sizing: border-box;
}

.custom-nav {
  background: #fff7fa;
  border-bottom: 1rpx solid #f2e6eb;
  box-sizing: border-box;
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.nav-side {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 52rpx;
  color: #111;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
}

.content {
  box-sizing: border-box;
}

.loading-wrap {
  padding: 240rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.status-card,
.section-card {
  margin: 16rpx 16rpx 0;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 4rpx 14rpx rgba(31, 35, 41, 0.04);
  box-sizing: border-box;
}

.status-card {
  background: linear-gradient(180deg, #ffe8ef 0%, #fff7fa 100%);
}

.status-top-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.status-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #ff5f8d;
  line-height: 1.2;
}

.status-order-no {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9aa0aa;
}

.status-price {
  font-size: 54rpx;
  font-weight: 800;
  color: #ff5f8d;
  line-height: 1.1;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
  margin-bottom: 18rpx;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.detail-row + .detail-row {
  margin-top: 16rpx;
}

.label {
  font-size: 24rpx;
  color: #8b8f97;
}

.value {
  font-size: 26rpx;
  color: #222;
  font-weight: 700;
  text-align: right;
}

.schedule-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.schedule-item {
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 18rpx 18rpx;
}

.schedule-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.schedule-date {
  font-size: 28rpx;
  font-weight: 800;
  color: #222;
  line-height: 1.3;
}

.schedule-status {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fff1f5;
  color: #ff5f8d;
  font-size: 22rpx;
  line-height: 1.2;
}

.schedule-bottom {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.schedule-time {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  flex: 1;
  min-width: 0;
}

.schedule-duration {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #8b8f97;
  line-height: 1.2;
}

.pet-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.pet-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx;
  background: #f8f9fc;
  border-radius: 18rpx;
}

.pet-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: #eee;
  flex-shrink: 0;
}

.pet-info {
  flex: 1;
}

.pet-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #222;
}

.pet-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8b8f97;
}

.address-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
}

.address-text,
.remark-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.7;
}

.total-box {
  margin-top: 20rpx;
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
  background: #fff1f5;
  color: #ff5f8d;
  font-size: 30rpx;
  font-weight: 800;
  text-align: center;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: flex;
  gap: 18rpx;
  padding: 14rpx 20rpx calc(14rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}

.action-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 18rpx;
}

.full-btn {
  flex: 1 1 100%;
}

.ghost-btn {
  background: #fff;
  color: #666;
  border: 1rpx solid #eceef2;
}

.page-bottom-space {
  height: 28rpx;
}

.pet-section-card {
  padding-top: 22rpx;
  padding-bottom: 20rpx;
}

.pet-section-title-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.pet-section-icon {
  font-size: 24rpx;
  line-height: 1;
}

.pet-inline-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  column-gap: 18rpx;
  row-gap: 14rpx;
}

.pet-inline-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.pet-inline-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
}

.pet-inline-info {
  flex: 1;
  min-width: 0;
}

.pet-inline-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #222;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.pet-inline-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8b8f97;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.pet-inline-tags {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.pet-inline-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 46rpx;
  height: 32rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #fff1f5;
  color: #ff7da1;
  font-size: 18rpx;
  line-height: 1;
  box-sizing: border-box;
}

/* 浮层 */
.pet-popup-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 99;
  background: rgba(0, 0, 0, 0.38);
  display: flex;
  align-items: flex-end;
}

.pet-popup-panel {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 18rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.pet-popup-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #e4e7ec;
  margin: 0 auto 20rpx;
}

.pet-popup-header {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.pet-popup-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
}

.pet-popup-header-info {
  flex: 1;
  min-width: 0;
}

.pet-popup-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #222;
  line-height: 1.3;
}

.pet-popup-type {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.5;
}

.pet-popup-section {
  margin-top: 24rpx;
  background: #f8f9fc;
  border-radius: 20rpx;
  padding: 18rpx 18rpx;
}

.pet-popup-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.pet-popup-row + .pet-popup-row {
  margin-top: 18rpx;
}

.pet-popup-row.column {
  align-items: flex-start;
  flex-direction: column;
}

.pet-popup-label {
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.4;
}

.pet-popup-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.6;
  text-align: right;
}

.pet-popup-value.text-left {
  text-align: left;
  font-weight: 500;
}

.pet-popup-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 18rpx;
  margin-top: 24rpx;
}