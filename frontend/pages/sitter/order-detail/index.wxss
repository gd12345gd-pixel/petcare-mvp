.sitter-detail-page {
  min-height: 100vh;
  background: #f7f8fb;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

.custom-nav {
  background: #fff7fa;
  border-bottom: 1rpx solid #f2e6eb;
  box-sizing: border-box;
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.nav-side {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 52rpx;
  color: #111;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
}

.content {
  box-sizing: border-box;
}

.loading-wrap {
  padding: 240rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.status-card,
.section-card {
  margin: 16rpx 16rpx 0;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 4rpx 14rpx rgba(31, 35, 41, 0.04);
  box-sizing: border-box;
}

.compact-card {
  border-radius: 24rpx;
}

.status-top-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.status-main {
  flex: 1;
  min-width: 0;
}

.status-title {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
}

.status-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8b8f97;
}

.status-order-no {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #9aa0aa;
}

.status-price-wrap {
  flex-shrink: 0;
  text-align: right;
}

.status-price-label {
  font-size: 20rpx;
  color: #9aa0aa;
  line-height: 1.2;
}

.status-price {
  margin-top: 8rpx;
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1.1;
}

.status-wait-taking {
  background: linear-gradient(180deg, #ffe8ef 0%, #fff7fa 100%);
}
.status-wait-taking .status-title,
.status-wait-taking .status-price {
  color: #ff5f8d;
}

.status-taken {
  background: linear-gradient(180deg, #fff3e4 0%, #fffaf6 100%);
}
.status-taken .status-title,
.status-taken .status-price {
  color: #ff8a00;
}

.status-serving {
  background: linear-gradient(180deg, #edf6ff 0%, #f8fbff 100%);
}
.status-serving .status-title,
.status-serving .status-price {
  color: #3a8bff;
}

.status-part-completed {
  background: linear-gradient(180deg, #fff5e9 0%, #fffdfa 100%);
}
.status-part-completed .status-title,
.status-part-completed .status-price {
  color: #ff8a00;
}

.status-completed {
  background: linear-gradient(180deg, #edf9f1 0%, #f8fdf9 100%);
}
.status-completed .status-title,
.status-completed .status-price {
  color: #22a15f;
}

.status-cancelled {
  background: linear-gradient(180deg, #f4f4f4 0%, #fafafa 100%);
}
.status-cancelled .status-title,
.status-cancelled .status-price {
  color: #999;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
}

.section-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fff1f5;
  color: #ff5f8d;
  font-size: 20rpx;
  line-height: 1.2;
  flex-shrink: 0;
}

.summary-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.summary-row + .summary-row {
  margin-top: 18rpx;
}

.summary-icon {
  width: 34rpx;
  text-align: center;
  font-size: 26rpx;
  line-height: 1;
  flex-shrink: 0;
}

.summary-label {
  width: 120rpx;
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.4;
  flex-shrink: 0;
}

.summary-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.5;
}

.summary-divider {
  margin: 22rpx 0 18rpx;
  height: 1rpx;
  background: #f0f1f3;
}

.summary-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  flex-wrap: wrap;
}

.progress-text {
  font-size: 30rpx;
  font-weight: 800;
  color: #ff5f8d;
  line-height: 1.3;
}

.progress-subtext {
  font-size: 22rpx;
  color: #9aa0aa;
  line-height: 1.5;
}

.pending-tip {
  margin-top: 16rpx;
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 18rpx 18rpx;
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.7;
}

.schedule-item {
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 18rpx 18rpx;
}

.schedule-item-focus {
  background: linear-gradient(180deg, #fff7fa 0%, #f8f9fc 100%);
}

.schedule-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.schedule-date {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
  line-height: 1.3;
}

.schedule-status {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.2;
}

.schedule-status-LOCKED {
  background: #f3f4f6;
  color: #b0b4bb;
}

.schedule-status-PENDING {
  background: #fff3e6;
  color: #ff8a00;
}

.schedule-status-SERVING {
  background: #eef5ff;
  color: #3a8bff;
}

.schedule-status-RECORDED {
  background: #fff1f5;
  color: #ff5f8d;
}

.schedule-status-DONE {
  background: #edf9f1;
  color: #22a15f;
}

.schedule-status-CANCELLED {
  background: #f3f4f6;
  color: #999;
}

.schedule-main {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.schedule-time {
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.5;
  flex: 1;
  min-width: 0;
}

.schedule-duration {
  font-size: 22rpx;
  color: #9aa0aa;
  line-height: 1.2;
  flex-shrink: 0;
}

.schedule-actions {
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.schedule-btn {
  min-width: 180rpx;
  height: 64rpx;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.schedule-compact-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.schedule-compact-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 14rpx;
  background: #f8f9fc;
  border-radius: 16rpx;
}

.schedule-compact-left {
  flex: 1;
  min-width: 0;
}

.schedule-compact-date {
  font-size: 26rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.4;
}

.schedule-compact-time {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #9aa0aa;
  line-height: 1.4;
}

.schedule-compact-right {
  flex-shrink: 0;
  text-align: right;
}

.schedule-compact-status {
  display: inline-flex;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.2;
}

.schedule-compact-duration {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #9aa0aa;
  line-height: 1.2;
}

.pet-grid {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.pet-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 16rpx;
}

.pet-card-image {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: #eee;
  flex-shrink: 0;
}

.pet-card-info {
  flex: 1;
  min-width: 0;
}

.pet-card-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #222;
  line-height: 1.3;
}

.pet-card-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8b8f97;
  line-height: 1.4;
}

.detail-block-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #222;
  line-height: 1.4;
}

.detail-block-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.6;
}

.remark-box {
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 18rpx 20rpx;
  font-size: 26rpx;
  color: #222;
  line-height: 1.8;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.price-row + .price-row {
  margin-top: 18rpx;
}

.price-label {
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.4;
}

.price-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.4;
}

.total-box {
  margin-top: 20rpx;
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
  background: #fff1f5;
  color: #ff5f8d;
  font-size: 30rpx;
  font-weight: 800;
  text-align: center;
  line-height: 1.5;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: flex;
  gap: 18rpx;
  padding: 14rpx 20rpx calc(14rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}

.action-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 18rpx;
}

.ghost-btn {
  background: #fff;
  color: #666;
  border: 1rpx solid #eceef2;
}

.page-bottom-space {
  height: 36rpx;
}