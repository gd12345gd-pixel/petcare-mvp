<view class="sitter-detail-page">
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-side nav-left" bindtap="navigateBack">
        <view class="nav-back-hit">
          <view class="nav-back-icon"></view>
        </view>
      </view>
      <view class="nav-title">接单详情</view>
      <view class="nav-side"></view>
    </view>
  </view>

  <scroll-view class="content" scroll-y style="height: calc(100vh - {{navTotalHeight}}px - {{order && order.canTake ? 170 : 0}}rpx);">
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-text">加载中...</view>
    </view>

    <block wx:elif="{{order}}">
      <!-- 顶部状态卡 -->
      <view class="status-card {{order.statusClass}}">
        <view class="status-top-row">
          <view class="status-main">
            <view class="status-title">{{order.headerTitle}}</view>
            <view class="status-desc">{{order.headerDesc}}</view>

            <view class="status-order-row">
              <view class="status-order-no">订单号：{{order.orderNo}}</view>
              <view class="copy-order-btn" bindtap="copyOrderNo">复制</view>
            </view>
          </view>

          <view class="status-price-wrap">
            <view class="status-price-label">总价</view>
            <view class="status-price">¥{{order.totalPriceText}}</view>
          </view>
        </view>
      </view>

      <!-- 服务安排（含日期明细入口与展开内容） -->
      <view class="section-card">
        <view class="section-title">服务安排</view>

        <view class="arrange-row">
          <view class="arrange-left">
            <view class="arrange-icon">🗓</view>
            <view class="arrange-label">服务日期</view>
          </view>
          <view class="arrange-right">{{order.serviceDateSummaryText}}</view>
        </view>

        <view class="arrange-row">
          <view class="arrange-left">
            <view class="arrange-icon">⏰</view>
            <view class="arrange-label">服务时间</view>
          </view>
          <view class="arrange-right">{{order.serviceTimeSummaryText}}</view>
        </view>

        <view class="arrange-row">
          <view class="arrange-left">
            <view class="arrange-icon">⌛</view>
            <view class="arrange-label">服务时长</view>
          </view>
          <view class="arrange-right">{{order.serviceDurationSummaryText}}</view>
        </view>

        <view class="schedule-toggle-wrap" wx:if="{{order.showScheduleToggle}}" bindtap="toggleScheduleExpand">
          <view class="schedule-toggle-left">
            <view class="schedule-toggle-title">全部日期明细</view>
            <view class="schedule-toggle-desc">
              {{showAllSchedules ? '点击收起日期明细' : '点击展开查看每次服务安排'}}
            </view>
          </view>
          <view class="schedule-toggle-right">
            <view class="schedule-toggle-main">{{showAllSchedules ? '收起' : '查看全部'}}</view>
            <view class="schedule-toggle-count">{{order.progressCountText}}</view>
          </view>
        </view>

        <view class="schedule-list" wx:if="{{showAllSchedules}}">
          <view class="schedule-item" wx:for="{{order.serviceDates}}" wx:key="scheduleId">
            <view class="schedule-top">
              <view class="schedule-date">{{item.serviceDateText}}</view>
              <view class="schedule-status schedule-status-{{item.scheduleStatus}}">
                {{item.scheduleStatusText}}
              </view>
            </view>

            <view class="schedule-middle">
              <view class="schedule-time">{{item.timeSlotsText}}</view>
              <view class="schedule-duration">{{item.serviceDurationMinutes}}分钟</view>
            </view>

            <view class="schedule-bottom">
              <view class="schedule-hint">{{item.scheduleHintText}}</view>

              <view class="schedule-action-row">
                <button
                  class="schedule-mini-btn schedule-mini-btn-primary"
                  wx:if="{{item.canStartSchedule}}"
                  data-schedule-id="{{item.scheduleId}}"
                  bindtap="handleStartSchedule"
                >
                  开始服务
                </button>

                <button
                  class="schedule-mini-btn schedule-mini-btn-ghost"
                  wx:if="{{item.canWriteRecord}}"
                  data-schedule-id="{{item.scheduleId}}"
                  bindtap="goWriteServiceRecord"
                >
                  填写记录
                </button>

                <button
                  class="schedule-mini-btn schedule-mini-btn-primary"
                  wx:if="{{item.canFinishSchedule}}"
                  data-schedule-id="{{item.scheduleId}}"
                  bindtap="handleFinishSchedule"
                >
                  结束服务
                </button>

                <button
                  class="schedule-mini-btn schedule-mini-btn-ghost"
                  wx:if="{{item.canViewRecord}}"
                  data-record-id="{{item.recordId}}"
                  bindtap="handleViewRecord"
                >
                  查看记录
                </button>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 今日待服务 -->
      <view class="section-card" wx:if="{{order.todayTask}}">
        <view class="section-title no-margin">{{order.todayTask.title}}</view>

        <view class="today-task-box" wx:if="{{order.todayTask.item}}">
          <view class="today-task-top">
            <view class="today-task-date">{{order.todayTask.item.serviceDateText}}</view>
            <view class="schedule-status schedule-status-{{order.todayTask.item.scheduleStatus}}">
              {{order.todayTask.item.scheduleStatusText}}
            </view>
          </view>

          <view class="today-task-time">
            {{order.todayTask.item.timeSlotsText}} · {{order.todayTask.item.serviceDurationMinutes}}分钟
          </view>
          <view class="today-task-desc">{{order.todayTask.desc}}</view>

          <view class="today-task-actions">
            <button
              class="primary-btn schedule-btn"
              wx:if="{{order.todayTask.item.canStartSchedule}}"
              data-schedule-id="{{order.todayTask.item.scheduleId}}"
              bindtap="handleStartSchedule"
            >
              开始本次服务
            </button>

            <button
              class="ghost-btn schedule-btn"
              wx:if="{{order.todayTask.item.canWriteRecord}}"
              data-schedule-id="{{order.todayTask.item.scheduleId}}"
              bindtap="goWriteServiceRecord"
            >
              填写服务记录
            </button>

            <button
              class="primary-btn schedule-btn"
              wx:if="{{order.todayTask.item.canFinishSchedule}}"
              data-schedule-id="{{order.todayTask.item.scheduleId}}"
              bindtap="handleFinishSchedule"
            >
              结束本次服务
            </button>

            <button
              class="ghost-btn schedule-btn"
              wx:if="{{order.todayTask.item.canViewRecord}}"
              data-record-id="{{order.todayTask.item.recordId}}"
              bindtap="handleViewRecord"
            >
              查看服务记录
            </button>
          </view>
        </view>

        <view class="today-empty-box" wx:else>
          <view class="today-empty-desc">{{order.todayTask.desc}}</view>
        </view>
      </view>

      <!-- 服务宠物 -->
      <view class="section-card pet-section-card">
        <view class="section-head">
          <view class="pet-section-title-wrap">
            <view class="section-title no-margin">服务宠物</view>
          </view>
          <view class="section-subtitle">点击查看详情</view>
        </view>

        <view class="pet-inline-grid">
          <view
            class="pet-inline-item"
            wx:for="{{order.pets}}"
            wx:key="petId"
            data-index="{{index}}"
            bindtap="openPetDetail"
          >
            <image class="pet-inline-avatar" src="{{item.petImageUrl}}" mode="aspectFill" />

            <view class="pet-inline-info">
              <view class="pet-inline-name">{{item.petName}}</view>
              <view class="pet-inline-meta">{{item.petTypeText}} · {{item.petBreedText}}</view>
              <view class="pet-inline-tags" wx:if="{{item.petGenderText || item.petAgeText}}">
                <text class="pet-inline-tag" wx:if="{{item.petGenderText}}">{{item.petGenderText}}</text>
                <text class="pet-inline-tag" wx:if="{{item.petAgeText}}">{{item.petAgeText}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 服务地址 -->
      <view class="section-card">
        <view class="section-title">服务地址</view>
        <view class="detail-block-title">{{order.serviceContactName}} {{order.serviceContactPhone}}</view>
        <view class="detail-block-desc">{{order.serviceFullAddress}}</view>
      </view>

      <!-- 照护备注 -->
      <view class="section-card">
        <view class="section-head">
          <view class="section-title no-margin">照护备注</view>
          <view class="new-remark-badge" wx:if="{{order.hasSupplementRemark}}">有新的补充说明</view>
        </view>

        <view class="remark-timeline" wx:if="{{order.remarkTimeline && order.remarkTimeline.length}}">
          <view class="remark-timeline-item" wx:for="{{order.remarkTimeline}}" wx:key="id">
            <view class="remark-dot"></view>
            <view class="remark-card">
              <view class="remark-title">{{item.title}}</view>
              <view class="remark-content">{{item.content}}</view>
              <view class="remark-images" wx:if="{{item.imageUrls && item.imageUrls.length}}">
                <image
                  class="remark-image"
                  wx:for="{{item.imageUrls}}"
                  wx:for-item="imageUrl"
                  wx:key="*this"
                  src="{{imageUrl}}"
                  mode="aspectFill"
                  data-url="{{imageUrl}}"
                  data-urls="{{item.imageUrls}}"
                  bindtap="previewRemarkImage"
                />
              </view>
            </view>
          </view>
        </view>

        <view class="remark-box" wx:else>暂无备注</view>
      </view>

      <!-- 费用明细 -->
      <view class="section-card">
        <view class="section-title">费用明细</view>

        <view class="price-row">
          <text class="price-label">服务单价</text>
          <text class="price-value">¥{{order.unitPriceText}}/次</text>
        </view>

        <view class="price-row">
          <text class="price-label">服务次数</text>
          <text class="price-value">{{order.serviceDateCount}}次</text>
        </view>

        <view class="summary-total-box">
          <view class="summary-total-text">合计总价</view>
          <view class="summary-total-price">¥{{order.totalPriceText}}</view>
        </view>
      </view>

      <view class="page-bottom-space"></view>
    </block>
  </scroll-view>

  <view class="bottom-bar order-bottom-bar" wx:if="{{order && !loading && order.canTake}}">
    <button class="secondary-btn order-action-btn cancel-btn" bindtap="navigateBack">
      暂不接
    </button>

    <button class="primary-btn order-action-btn" bindtap="handleTakeOrder">
      确认接单
    </button>
  </view>

  <!-- 宠物详情浮层 -->
  <view class="pet-popup-mask" wx:if="{{showPetPopup}}" bindtap="closePetDetail">
    <view class="pet-popup-panel" catchtap="stopPopupBubble">
      <view class="pet-popup-handle"></view>

      <view class="pet-popup-header">
        <image class="pet-popup-avatar" src="{{activePet.petImageUrl}}" mode="aspectFill" />
        <view class="pet-popup-header-info">
          <view class="pet-popup-name">{{activePet.petName}}</view>
          <view class="pet-popup-type">{{activePet.petTypeText}} · {{activePet.petBreedText}}</view>
        </view>
      </view>

      <view class="pet-popup-section">
        <view class="pet-popup-row" wx:if="{{activePet.petGenderText}}">
          <view class="pet-popup-label">性别</view>
          <view class="pet-popup-value">{{activePet.petGenderText}}</view>
        </view>

        <view class="pet-popup-row" wx:if="{{activePet.petAgeText}}">
          <view class="pet-popup-label">年龄</view>
          <view class="pet-popup-value">{{activePet.petAgeText}}</view>
        </view>
        <view class="pet-popup-row" wx:if="{{activePet.petWeightText}}">
          <view class="pet-popup-label">体重</view>
          <view class="pet-popup-value">{{activePet.petWeightText}}</view>
        </view>
        <view class="pet-popup-row" wx:if="{{activePet.petVaccinatedText}}">
          <view class="pet-popup-label">疫苗</view>
          <view class="pet-popup-value">{{activePet.petVaccinatedText}}</view>
        </view>
        <view class="pet-popup-row" wx:if="{{activePet.petAggressionText}}">
          <view class="pet-popup-label">攻击性</view>
          <view class="pet-popup-value">{{activePet.petAggressionText}}</view>
        </view>
        <view class="pet-popup-row column" wx:if="{{activePet.petTags && activePet.petTags.length}}">
          <view class="pet-popup-label">标签</view>
          <view class="pet-popup-tags">
            <view class="pet-popup-tag" wx:for="{{activePet.petTags}}" wx:key="*this">{{item}}</view>
          </view>
        </view>
        <view class="pet-popup-row column" wx:if="{{activePet.petAlbumList && activePet.petAlbumList.length}}">
          <view class="pet-popup-label">相册</view>
          <scroll-view class="pet-popup-album-scroll" scroll-x>
            <view class="pet-popup-album">
              <image
                class="pet-popup-album-image"
                wx:for="{{activePet.petAlbumList}}"
                wx:key="*this"
                src="{{item}}"
                mode="aspectFill"
              />
            </view>
          </scroll-view>
        </view>

        <view class="pet-popup-row column">
          <view class="pet-popup-label">照护备注</view>
          <view class="pet-popup-value text-left">{{activePet.petRemarkText}}</view>
        </view>
      </view>

      <button class="primary-btn pet-popup-btn" bindtap="closePetDetail">我知道了</button>
    </view>
  </view>
</view>
