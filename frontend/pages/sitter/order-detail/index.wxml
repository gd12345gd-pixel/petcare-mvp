<view class="sitter-detail-page">
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-side nav-left" bindtap="navigateBack">‹</view>
      <view class="nav-title">接单详情</view>
      <view class="nav-side"></view>
    </view>
  </view>

  <scroll-view class="content" scroll-y style="height: calc(100vh - {{navTotalHeight}}px - 170rpx);">
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-text">加载中...</view>
    </view>

    <block wx:elif="{{order}}">
      <view class="status-card">
        <view class="status-top-row">
          <view>
            <view class="status-title">{{order.orderStatusText}}</view>
            <view class="status-order-no">订单号：{{order.orderNo}}</view>
          </view>
          <view class="status-price">¥{{order.totalPriceText}}</view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-title">服务安排</view>

        <view class="detail-row">
          <text class="label">服务次数</text>
          <text class="value">{{order.serviceDateCount}}次</text>
        </view>

        <view class="schedule-list">
          <view class="schedule-item" wx:for="{{order.serviceDates}}" wx:key="serviceDate">
            <view class="schedule-top">
              <view class="schedule-date">{{item.serviceDateText}}</view>
              <view class="schedule-status">{{item.scheduleStatusText}}</view>
            </view>

            <view class="schedule-bottom">
              <view class="schedule-time">{{item.timeSlotsText}}</view>
              <view class="schedule-duration">{{item.serviceDurationMinutes}}分钟/次</view>
            </view>
          </view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-title">服务宠物</view>
        <view class="pet-list">
          <view class="pet-item" wx:for="{{order.pets}}" wx:key="petId">
            <image class="pet-avatar" src="{{item.petImageUrl}}" mode="aspectFill" />
            <view class="pet-info">
              <view class="pet-name">{{item.petName}}</view>
              <view class="pet-meta">{{item.petType || '未知类型'}}{{item.petBreed ? ' · ' + item.petBreed : ''}}</view>
            </view>
          </view>
        </view>
      </view>

      <view class="section-card">
        <view class="section-title">服务地址</view>
        <view class="address-name">{{order.serviceContactName}} {{order.serviceContactPhone}}</view>
        <view class="address-text">{{order.serviceFullAddress}}</view>
      </view>

      <view class="section-card">
        <view class="section-title">照护备注</view>
        <view class="remark-text">{{order.remark || '暂无备注'}}</view>
      </view>

      <view class="section-card">
        <view class="section-title">费用明细</view>
        <view class="detail-row">
          <text class="label">服务单价</text>
          <text class="value">¥{{order.unitPriceText}}/次</text>
        </view>
        <view class="detail-row">
          <text class="label">服务次数</text>
          <text class="value">{{order.serviceDateCount}}次</text>
        </view>
        <view class="total-box">合计总价 ¥{{order.totalPriceText}}</view>
      </view>

      <view class="page-bottom-space"></view>
    </block>
  </scroll-view>

  <view class="bottom-bar" wx:if="{{order && !loading}}">
    <button class="ghost-btn action-btn" wx:if="{{order.canTake}}" bindtap="navigateBack">暂不接</button>
    <button class="primary-btn action-btn" wx:if="{{order.canTake}}" bindtap="handleTakeOrder">确认接单</button>

    <button class="primary-btn action-btn full-btn" wx:if="{{order.canStart}}" bindtap="handleStartService">开始服务</button>
    <button class="primary-btn action-btn full-btn" wx:if="{{order.canComplete}}" bindtap="handleCompleteService">完成服务</button>
  </view>
</view>