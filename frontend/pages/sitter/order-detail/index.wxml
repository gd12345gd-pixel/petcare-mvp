<view class="sitter-detail-page">
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-side nav-left" bindtap="navigateBack">‹</view>
      <view class="nav-title">接单详情</view>
      <view class="nav-side"></view>
    </view>
  </view>

  <scroll-view class="content" scroll-y style="height: calc(100vh - {{navTotalHeight}}px - {{order && order.canTake ? 170 : 0}}rpx);">
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-text">加载中...</view>
    </view>

    <block wx:elif="{{order}}">
      <view class="status-card {{order.orderStatusClass}}">
        <view class="status-top-row">
          <view class="status-main">
            <view class="status-title">{{order.headerTitle}}</view>
            <view class="status-desc">{{order.headerDesc}}</view>
            <view class="status-order-no">订单号：{{order.orderNo}}</view>
          </view>
          <view class="status-price-wrap">
            <view class="status-price-label">总价</view>
            <view class="status-price">¥{{order.totalPriceText}}</view>
          </view>
        </view>
      </view>

      <view class="section-card compact-card">
        <view class="section-title">服务安排</view>

        <view class="summary-row">
          <view class="summary-icon">📅</view>
          <view class="summary-label">服务日期</view>
          <view class="summary-value">{{order.serviceDateSummary}}</view>
        </view>

        <view class="summary-row">
          <view class="summary-icon">⏰</view>
          <view class="summary-label">服务时间</view>
          <view class="summary-value">{{order.serviceTimeSummary}}</view>
        </view>

        <view class="summary-row">
          <view class="summary-icon">⌛</view>
          <view class="summary-label">服务时长</view>
          <view class="summary-value">{{order.serviceDurationSummary}}</view>
        </view>

        <view class="summary-divider"></view>

        <view class="summary-footer">
          <view class="progress-text">{{order.progressText}}</view>
          <view class="progress-subtext">{{order.progressSubText}}</view>
        </view>
      </view>

      <view class="section-card compact-card" wx:if="{{order.currentActionSchedule}}">
        <view class="section-head">
          <view class="section-title">今日待处理</view>
        </view>

        <view class="schedule-item schedule-item-focus">
          <view class="schedule-top">
            <view class="schedule-date">{{order.currentActionSchedule.serviceDateText}}</view>
            <view class="schedule-status schedule-status-{{order.currentActionSchedule.scheduleStatus}}">
              {{order.currentActionSchedule.scheduleStatusText}}
            </view>
          </view>

          <view class="schedule-main">
            <view class="schedule-time">{{order.currentActionSchedule.timeSlotsText}}</view>
            <view class="schedule-duration">{{order.currentActionSchedule.serviceDurationMinutes}}分钟</view>
          </view>

          <view class="schedule-actions" wx:if="{{order.currentActionSchedule.canStartSchedule || order.currentActionSchedule.canWriteRecord || order.currentActionSchedule.canFinishSchedule || order.currentActionSchedule.canViewRecord}}">
            <button
              class="primary-btn schedule-btn"
              wx:if="{{order.currentActionSchedule.canStartSchedule}}"
              data-schedule-id="{{order.currentActionSchedule.scheduleId}}"
              bindtap="handleStartSchedule"
            >
              开始本次服务
            </button>

            <button
              class="ghost-btn schedule-btn"
              wx:if="{{order.currentActionSchedule.canWriteRecord}}"
              data-schedule-id="{{order.currentActionSchedule.scheduleId}}"
              bindtap="goWriteServiceRecord"
            >
              填写服务记录
            </button>

            <button
              class="primary-btn schedule-btn"
              wx:if="{{order.currentActionSchedule.canFinishSchedule}}"
              data-schedule-id="{{order.currentActionSchedule.scheduleId}}"
              bindtap="handleFinishSchedule"
            >
              结束本次服务
            </button>

            <button
              class="ghost-btn schedule-btn"
              wx:if="{{order.currentActionSchedule.canViewRecord}}"
              data-record-id="{{order.currentActionSchedule.recordId}}"
              bindtap="handleViewRecord"
            >
              查看服务记录
            </button>
          </view>
        </view>
      </view>

      <view class="section-card compact-card">
        <view class="section-head">
          <view class="section-title">服务日期明细</view>
          <view class="section-tag">共{{order.scheduleCount}}次服务</view>
        </view>

        <view class="schedule-compact-list">
          <view class="schedule-compact-item" wx:for="{{order.serviceDates}}" wx:key="scheduleId">
            <view class="schedule-compact-left">
              <view class="schedule-compact-date">{{item.serviceDateText}}</view>
              <view class="schedule-compact-time">{{item.timeSlotsText}}</view>
            </view>

            <view class="schedule-compact-right">
              <view class="schedule-compact-status schedule-status-{{item.scheduleStatus}}">
                {{item.scheduleStatusText}}
              </view>
              <view class="schedule-compact-duration">{{item.serviceDurationMinutes}}分钟</view>
            </view>
          </view>
        </view>

        <view class="pending-tip" wx:if="{{order.canTake}}">
          接单后可按日期逐次开始服务并提交服务记录
        </view>
      </view>

      <view class="section-card compact-card">
        <view class="section-head">
          <view class="section-title">服务宠物</view>
        </view>

        <view class="pet-grid">
          <view class="pet-card" wx:for="{{order.pets}}" wx:key="petId">
            <image class="pet-card-image" src="{{item.petImageUrl}}" mode="aspectFill" />
            <view class="pet-card-info">
              <view class="pet-card-name">{{item.petName || '未命名宠物'}}</view>
              <view class="pet-card-meta">{{item.petType || '未知类型'}}{{item.petBreed ? ' · ' + item.petBreed : ''}}</view>
            </view>
          </view>
        </view>
      </view>

      <view class="section-card compact-card">
        <view class="section-head">
          <view class="section-title">服务地址</view>
        </view>

        <view class="detail-block-title">{{order.serviceContactName}} {{order.serviceContactPhone}}</view>
        <view class="detail-block-desc">{{order.serviceFullAddress}}</view>
      </view>

      <view class="section-card compact-card">
        <view class="section-head">
          <view class="section-title">照护备注</view>
        </view>
        <view class="remark-box">{{order.remark || '暂无备注'}}</view>
      </view>

      <view class="section-card compact-card">
        <view class="section-head">
          <view class="section-title">费用明细</view>
        </view>

        <view class="price-row">
          <text class="price-label">服务单价</text>
          <text class="price-value">¥{{order.unitPriceText}}/次</text>
        </view>

        <view class="price-row">
          <text class="price-label">服务次数</text>
          <text class="price-value">{{order.serviceDateCount}}次</text>
        </view>

        <view class="total-box">合计总价 ¥{{order.totalPriceText}}</view>
      </view>

      <view class="page-bottom-space"></view>
    </block>
  </scroll-view>

  <view class="bottom-bar" wx:if="{{order && !loading && order.canTake}}">
    <button class="ghost-btn action-btn" bindtap="navigateBack">暂不接</button>
    <button class="primary-btn action-btn" bindtap="handleTakeOrder">确认接单</button>
  </view>
</view>