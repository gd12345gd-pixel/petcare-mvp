.review-page {
  min-height: 100vh;
  background: #f7f8fb;
  padding-bottom: 170rpx;
  box-sizing: border-box;
}

.custom-nav {
  background: #fff7fa;
  border-bottom: 1rpx solid #f2e6eb;
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.nav-side {
  width: 96rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
}

.nav-back-hit {
  width: 96rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 22rpx;
  height: 22rpx;
  border-left: 5rpx solid #222;
  border-bottom: 5rpx solid #222;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.hero-card,
.form-card {
  margin: 16rpx 16rpx 0;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 4rpx 14rpx rgba(31, 35, 41, 0.04);
}

.hero-card {
  background: linear-gradient(180deg, #f8dfe7 0%, #fff4f7 100%);
}

.hero-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #222;
}

.hero-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7f858f;
  line-height: 1.55;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
  margin-bottom: 18rpx;
}

.no-margin {
  margin-bottom: 0;
}

.star-row {
  display: flex;
  justify-content: center;
  gap: 18rpx;
}

.star {
  font-size: 58rpx;
  color: #d8dbe2;
  line-height: 1;
}

.star.active {
  color: #ffb33f;
}

.rating-text {
  margin-top: 14rpx;
  text-align: center;
  color: #ff8a00;
  font-size: 24rpx;
  font-weight: 800;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-item {
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #f5f6fa;
  color: #666;
  font-size: 24rpx;
}

.tag-item.active {
  background: #fff1f5;
  color: #ff5f8d;
  font-weight: 800;
}

.form-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.count-text {
  font-size: 22rpx;
  color: #a0a4ad;
}

.review-textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f8f9fc;
  color: #222;
  font-size: 26rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.placeholder {
  color: #b8bcc5;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -6rpx 20rpx rgba(31, 35, 41, 0.06);
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
}
