<view class="order-detail-page">
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-side nav-left" bindtap="navigateBack">
  <view class="nav-back-hit">
    <text class="nav-back-icon">‹</text>
  </view>
</view>
      <view class="nav-title">订单详情</view>
      <view class="nav-side"></view>
    </view>
  </view>

  <scroll-view
    class="content"
    scroll-y
    style="height: calc(100vh - {{navTotalHeight}}px - 170rpx);"
  >
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-text">加载中...</view>
    </view>

    <block wx:elif="{{order}}">
      <view class="status-card {{order.statusClass}}">
        <view class="status-top">
          <view class="status-main">
            <view class="status-title">{{order.orderStatusText}}</view>
            <view class="status-desc">{{order.statusHintText}}</view>
          </view>
          <view class="status-pay-tag">{{order.payStatusText}}</view>
        </view>
        <view class="status-order-no">订单号：{{order.orderNo}}</view>
      </view>

      <view class="section-card compact-card">
        <view class="section-head">
          <view class="card-title">预约概览</view>
        </view>

        <view class="overview-grid">
          <view class="overview-item">
            <view class="overview-label">宠物数量</view>
            <view class="overview-value">{{order.petCount}}只</view>
          </view>

          <view class="overview-item">
            <view class="overview-label">服务次数</view>
            <view class="overview-value">{{order.serviceDateCount}}次</view>
          </view>

          <view class="overview-item">
            <view class="overview-label">服务时长</view>
            <view class="overview-value">{{order.serviceDurationMinutes}}分钟</view>
          </view>

          <view class="overview-item">
            <view class="overview-label">上门时间段</view>
            <view class="overview-value overview-value--small">{{order.timeSlotsText}}</view>
          </view>
        </view>
      </view>

      <view class="section-card compact-card">
        <view class="section-head">
          <view class="card-title">服务日期</view>
          <view class="section-tag">共 {{order.serviceDateCount}} 次</view>
        </view>

        <view class="schedule-list">
          <view class="schedule-item" wx:for="{{order.serviceDates}}" wx:key="serviceDate">
            <view class="schedule-top">
              <view class="schedule-date">{{item.serviceDateText}}</view>
              <view class="schedule-status">{{item.scheduleStatusText}}</view>
            </view>
            <view class="schedule-bottom">
              <view class="schedule-slot">{{item.timeSlotsText}}</view>
              <view class="schedule-duration">{{item.serviceDurationMinutes}}分钟</view>
            </view>
          </view>
        </view>
      </view>

      <view class="section-card compact-card">
        <view class="section-head">
          <view class="card-title">服务地址</view>
        </view>

        <view class="detail-block-title">{{order.serviceContactName}} {{order.serviceContactPhone}}</view>
        <view class="detail-block-desc">{{order.serviceFullAddress}}</view>
      </view>

      <view class="section-card compact-card">
        <view class="section-head">
          <view class="card-title">服务宠物</view>
          <view class="section-tag">共 {{order.petCount}} 只</view>
        </view>

        <scroll-view class="pet-scroll" scroll-x>
          <view class="pet-row">
            <view class="pet-card" wx:for="{{order.pets}}" wx:key="petId">
              <image
                class="pet-card-image"
                src="{{item.petImageUrl}}"
                mode="aspectFill"
              />
              <view class="pet-card-name">{{item.petName || '未命名宠物'}}</view>
              <view class="pet-card-meta">
                {{item.petType || '未知类型'}}{{item.petBreed ? ' · ' + item.petBreed : ''}}
              </view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="section-card compact-card">
        <view class="section-head">
          <view class="card-title">照护备注</view>
        </view>
        <view class="remark-box">{{order.remark}}</view>
      </view>

      <view class="section-card compact-card">
        <view class="section-head">
          <view class="card-title">价格信息</view>
        </view>

        <view class="price-row">
          <text class="price-label">平台建议单次价</text>
          <text class="price-value">¥{{order.suggestedUnitPrice}}</text>
        </view>

        <view class="price-row">
          <text class="price-label">确认单次价</text>
          <text class="price-value">¥{{order.unitPrice}}</text>
        </view>

        <view class="price-row">
          <text class="price-label">服务次数</text>
          <text class="price-value">{{order.serviceDateCount}}次</text>
        </view>

        <view class="summary-total-box">
          ¥{{order.unitPrice}} × {{order.serviceDateCount}}次 = ¥{{order.totalPrice}}
        </view>
      </view>

      <view class="page-bottom-space"></view>
    </block>

    <view class="empty-wrap" wx:else>
      <view class="empty-title">暂无订单信息</view>
    </view>
  </scroll-view>

  <view class="bottom-bar order-bottom-bar" wx:if="{{order && !loading}}">
    <button
      class="secondary-btn order-action-btn cancel-btn"
      wx:if="{{order.canCancel}}"
      bindtap="handleCancelOrder"
    >
      取消订单
    </button>

    <button
      class="secondary-btn order-action-btn"
      wx:else
      bindtap="handleContactService"
    >
      联系客服
    </button>

    <button class="primary-btn order-action-btn" bindtap="handleBookAgain">再约一次</button>
  </view>
</view>