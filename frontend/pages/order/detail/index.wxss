page {
  font-weight: 600;
  color: #2e2a2b;
}

.pet-list {
  display: flex;
  gap: 10px;
}

.pet-item {
  flex: 1;
  border: 1px solid #eee3e7;
  border-radius: 16px;
  padding: 12px;
}

.pet-avatar {
  width: 38px;
  height: 38px;
  border-radius: 19px;
  background: #f0ecee;
  margin-bottom: 8px;
}

.pet-name {
  font-size: 16px;
  font-weight: 600;
  color: #2e2a2b;
}

.remark-box {
  line-height: 1.7;
  color: #5f5a5c;
}

.page-bottom-space {
  height: 90px;
}

.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 12px;
  padding: 12px 16px 24px;
  background: #ffffff;
  box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.04);
}

.primary-btn,
.secondary-btn {
  flex: 1;
  height: 48px;
  line-height: 48px;
  border-radius: 24px;
  font-size: 16px;
  font-weight: 700;
}

.primary-btn {
  background: #ee6f95;
  color: #ffffff;
}

.secondary-btn {
  background: #fff;
  color: #2e2a2b;
  border: 1px solid #eadde2;
}