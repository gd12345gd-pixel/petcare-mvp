.order-detail-page {
  min-height: 100vh;
  background: #f7f8fb;
  padding-bottom: 190rpx;
  box-sizing: border-box;
}

/* 顶部导航 */
.custom-nav {
  position: relative;
  z-index: 20;
  background: #fff7fa;
  border-bottom: 1rpx solid #f2e6eb;
  box-sizing: border-box;
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  box-sizing: border-box;
  position: relative;
}

.nav-side {
  width: 96rpx;
  height: 88rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-left {
  position: relative;
  z-index: 21;
}

.nav-back-hit {
  position: relative;
  width: 96rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  position: relative;
  z-index: 1;
  width: 22rpx;
  height: 22rpx;
  border-left: 5rpx solid #222;
  border-bottom: 5rpx solid #222;
  transform: rotate(45deg);
  margin-left: 8rpx;
  box-sizing: border-box;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
}

/* 内容区域 */
.content {
  box-sizing: border-box;
}

.loading-wrap {
  padding: 220rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 公共卡片 */
.section-card {
  margin: 16rpx 16rpx 0;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 4rpx 14rpx rgba(31, 35, 41, 0.04);
  box-sizing: border-box;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
  margin-bottom: 18rpx;
}

.no-margin {
  margin-bottom: 0;
}

.section-subtitle {
  font-size: 22rpx;
  color: #9aa0aa;
  line-height: 1.2;
}

/* 状态卡 */
.status-card {
  margin: 18rpx 16rpx 0;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
}

 

.status-title {
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.2;
}

.status-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #8b8f97;
}

.status-order-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.status-order-no {
  font-size: 22rpx;
  color: #9aa0aa;
  line-height: 1.4;
}

.copy-order-btn {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.75);
  color: #666;
  font-size: 20rpx;
  line-height: 1.2;
}

 

 

.status-main {
  width: 100%;
  min-width: 0;
}

.status-wait-taking {
  background: linear-gradient(180deg, #ffe8ef 0%, #fff7fa 100%);
}
.status-wait-taking .status-title,
.status-wait-taking .status-price {
  color: #ff5f8d;
}

.status-taken {
  background: linear-gradient(180deg, #fff3e4 0%, #fffaf6 100%);
}
.status-taken .status-title,
.status-taken .status-price {
  color: #ff8a00;
}

.status-serving {
  background: linear-gradient(180deg, #edf6ff 0%, #f8fbff 100%);
}
.status-serving .status-title,
.status-serving .status-price {
  color: #3a8bff;
}

.status-part-completed {
  background: linear-gradient(180deg, #fff5e9 0%, #fffdfa 100%);
}
.status-part-completed .status-title,
.status-part-completed .status-price {
  color: #ff8a00;
}

.status-completed {
  background: linear-gradient(180deg, #edf9f1 0%, #f8fdf9 100%);
}
.status-completed .status-title,
.status-completed .status-price {
  color: #22a15f;
}

.status-cancelled {
  background: linear-gradient(180deg, #f4f4f4 0%, #fafafa 100%);
}
.status-cancelled .status-title,
.status-cancelled .status-price {
  color: #999;
}

/* 服务安排 */
.arrange-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.arrange-row + .arrange-row {
  margin-top: 20rpx;
}

.arrange-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 170rpx;
}

.arrange-icon {
  width: 34rpx;
  text-align: center;
  font-size: 22rpx;
  line-height: 1;
}

.arrange-label {
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.4;
}

.arrange-right {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.6;
}

.schedule-toggle-wrap {
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f1f3f6;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.schedule-toggle-left {
  flex: 1;
  min-width: 0;
}

.schedule-toggle-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.4;
}

.schedule-toggle-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #9aa0aa;
  line-height: 1.5;
}

.schedule-toggle-right {
  text-align: right;
  flex-shrink: 0;
}

.schedule-toggle-main {
  font-size: 24rpx;
  color: #ff5f8d;
  font-weight: 700;
  line-height: 1.3;
}

.schedule-toggle-count {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #b3b7c0;
  line-height: 1.2;
}

.schedule-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.schedule-item {
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 16rpx 16rpx;
}

.schedule-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.schedule-date {
  font-size: 28rpx;
  font-weight: 800;
  color: #222;
  line-height: 1.3;
}

.schedule-status {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.2;
}

.schedule-status-PENDING {
  background: #f3f4f6;
  color: #8b8f97;
}

.schedule-status-SERVING {
  background: #eef5ff;
  color: #3a8bff;
}

.schedule-status-RECORDED {
  background: #fff3e6;
  color: #ff8a00;
}

.schedule-status-DONE {
  background: #edf9f1;
  color: #22a15f;
}

.schedule-status-CANCELLED {
  background: #f3f4f6;
  color: #999;
}

.schedule-middle {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.schedule-time {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  flex: 1;
  min-width: 0;
}

.schedule-duration {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #9aa0aa;
  line-height: 1.2;
}

.schedule-bottom {
  margin-top: 10rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 12rpx;
}

.schedule-hint {
  font-size: 22rpx;
  color: #9aa0aa;
  line-height: 1.5;
  flex: 1;
  min-width: 0;
}

.schedule-record-link {
  flex-shrink: 0;
  min-height: 44rpx;
  padding: 0 2rpx 0 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #ff5f8d;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.schedule-record-arrow {
  margin-left: 4rpx;
  font-size: 28rpx;
  line-height: 1;
}

/* 今日服务 */
.today-task-box {
  background: #fff7fa;
  border-radius: 18rpx;
  padding: 18rpx 18rpx;
}

.today-task-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.today-task-date {
  font-size: 28rpx;
  font-weight: 800;
  color: #222;
}

.today-task-time {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.today-task-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8b8f97;
  line-height: 1.6;
}

.today-task-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.record-view-btn {
  min-width: 188rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #ff5f8d;
  border: 1rpx solid #ffd6e2;
  font-size: 24rpx;
  font-weight: 700;
  margin: 0;
  box-sizing: border-box;
}

.record-view-btn::after {
  border: none;
}

.today-empty-box {
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 20rpx 18rpx;
}

.today-empty-desc {
  font-size: 22rpx;
  color: #8b8f97;
  line-height: 1.6;
}

/* 宠物卡片 */
.pet-section-card {
  padding-top: 22rpx;
  padding-bottom: 20rpx;
}

.pet-section-title-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.pet-inline-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  column-gap: 18rpx;
  row-gap: 14rpx;
}

.pet-inline-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.pet-inline-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
}

.pet-inline-info {
  flex: 1;
  min-width: 0;
}

.pet-inline-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #222;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.pet-inline-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8b8f97;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.pet-inline-tags {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.pet-inline-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 46rpx;
  height: 32rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #fff1f5;
  color: #ff7da1;
  font-size: 18rpx;
  line-height: 1;
  box-sizing: border-box;
}

/* 地址 */
.detail-block-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #222;
  line-height: 1.4;
}

.detail-block-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.6;
}

/* 备注 */
.remark-box {
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 18rpx 20rpx;
  font-size: 26rpx;
  color: #222;
  line-height: 1.8;
}

/* 服务记录 */
.loading-inline {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.record-empty {
  background: #fafbfc;
  border-radius: 18rpx;
  padding: 26rpx 20rpx;
  text-align: center;
}

.record-empty-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #222;
}

.record-empty-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #9aa0aa;
  line-height: 1.6;
}

.record-list-item {
  background: #f8f9fc;
  border-radius: 18rpx;
  padding: 18rpx;
}

.record-list-item + .record-list-item {
  margin-top: 14rpx;
}

.record-list-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.record-list-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #222;
}

.record-list-arrow {
  font-size: 30rpx;
  color: #c3c7cf;
  line-height: 1;
}

.record-list-meta {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.record-list-status,
.record-list-image-count {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.2;
}

.record-list-status {
  background: #fff1f5;
  color: #ff5f8d;
}

.record-list-image-count {
  background: #f1f3f6;
  color: #8b8f97;
}

.record-list-time {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9aa0aa;
  line-height: 1.5;
}

/* 费用 */
.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.price-row + .price-row {
  margin-top: 18rpx;
}

.price-label {
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.4;
}

.price-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.4;
}

.summary-total-box {
  margin-top: 22rpx;
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
  background: #fff1f5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.summary-total-text {
  font-size: 24rpx;
  color: #ff7a9e;
  line-height: 1.4;
}

.summary-total-price {
  font-size: 36rpx;
  font-weight: 800;
  color: #ff5f8d;
  line-height: 1.2;
}

/* 空态 */
.empty-wrap {
  padding: 220rpx 0;
  text-align: center;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
}

/* 底部操作栏 */
.order-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: flex;
  gap: 18rpx;
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #f0f0f0;
  backdrop-filter: blur(10rpx);
  box-sizing: border-box;
}

.order-action-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 18rpx;
}

.cancel-btn {
  background: #fff3f3;
  color: #ff6b6b;
}

.page-bottom-space {
  height: 32rpx;
}

/* 宠物详情浮层 */
.pet-popup-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 99;
  background: rgba(0, 0, 0, 0.38);
  display: flex;
  align-items: flex-end;
}

.pet-popup-panel {
  width: 100%;
  max-height: 82vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 18rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.pet-popup-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #e4e7ec;
  margin: 0 auto 20rpx;
}

.pet-popup-header {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.pet-popup-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
}

.pet-popup-header-info {
  flex: 1;
  min-width: 0;
}

.pet-popup-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #222;
  line-height: 1.3;
}

.pet-popup-type {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.5;
}

.pet-popup-section {
  margin-top: 24rpx;
  background: #f8f9fc;
  border-radius: 20rpx;
  padding: 18rpx 18rpx;
}

.pet-popup-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.pet-popup-row + .pet-popup-row {
  margin-top: 18rpx;
}

.pet-popup-row.column {
  align-items: flex-start;
  flex-direction: column;
}

.pet-popup-label {
  font-size: 24rpx;
  color: #8b8f97;
  line-height: 1.4;
}

.pet-popup-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.6;
  text-align: right;
}

.pet-popup-value.text-left {
  text-align: left;
  font-weight: 500;
}

.pet-popup-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.pet-popup-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fff1f5;
  color: #ff5f8d;
  font-size: 22rpx;
  line-height: 1.2;
}

.pet-popup-album-scroll {
  width: 100%;
  white-space: nowrap;
}

.pet-popup-album {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 8rpx;
}

.pet-popup-album-image {
  width: 128rpx;
  height: 128rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
}

.pet-popup-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 18rpx;
  margin-top: 24rpx;
}
