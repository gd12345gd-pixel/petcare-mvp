<view class="order-list-page">
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-side"></view>
      <view class="nav-title">我的订单</view>
      <view class="nav-side"></view>
    </view>
  </view>

  <scroll-view
    class="content"
    scroll-y
    style="height: calc(100vh - {{navTotalHeight}}px);"
  >
    <view class="loading-wrap" wx:if="{{loading}}">
      <view class="loading-text">加载中...</view>
    </view>

    <view class="empty-wrap" wx:elif="{{!orders.length}}">
      <view class="empty-illustration">📦</view>
      <view class="empty-title">还没有订单</view>
      <view class="empty-desc">{{isLoggedIn ? '去预约一次上门照护吧' : '登录后可查看预约进度和服务记录'}}</view>
      <button class="primary-btn empty-btn" bindtap="goCreateOrder">去预约</button>
    </view>

    <block wx:else>
      <view class="list-hero">
        <view class="page-title">我的订单</view>
        <view class="desc-text list-subtitle">查看预约进度、服务安排与订单详情</view>
      </view>

      <scroll-view class="tab-scroll" scroll-x>
        <view class="tab-row">
          <view
            class="tab-item {{currentTab == item.key ? 'active' : ''}}"
            wx:for="{{tabs}}"
            wx:key="key"
            data-key="{{item.key}}"
            bindtap="switchTab"
          >
            {{item.label}}
          </view>
        </view>
      </scroll-view>

      <view class="flat-order-list" wx:if="{{currentTab == 'ALL'}}">
        <view
          class="order-card flat-order-card {{order.orderStatusClass}}"
          wx:for="{{filteredOrders}}"
          wx:for-item="order"
          wx:key="id"
        >
          <view class="order-main-row">
            <view class="order-date-wrap">
              <view class="order-date">{{order.serviceDateRangeText}}</view>
            </view>
            <view class="order-total">¥{{order.totalPriceText}}</view>
          </view>

          <view class="pet-line">
            <view class="pet-avatar"></view>
            <view class="pet-summary">{{order.petCountText || (order.petCount + '只宠物')}}</view>
            <view class="order-status-badge">{{order.orderStatusDisplayText}}</view>
          </view>

          <view class="compact-info-row">
            <view class="next-service-text">{{order.nextServiceText}}</view>
            <view class="compact-divider"></view>
            <view class="compact-meta">{{order.serviceMetaText}}</view>
          </view>

          <view class="progress-wrap" wx:if="{{order.showProgress}}">
            <view class="progress-head">
              <view class="progress-text">{{order.progressText}}</view>
              <view class="progress-percent">{{order.progressPercent}}%</view>
            </view>
            <view class="progress-track">
              <view class="progress-bar" style="width: {{order.progressPercent}}%;"></view>
            </view>
          </view>

          <view class="address-row">
            <view class="address-text">{{order.serviceFullAddress || '服务地址待确认'}}</view>
          </view>

          <view class="order-footer-row">
            <view class="order-no">订单号：{{order.orderNo}}</view>
            <view class="action-row compact-actions">
              <button
                class="plain-action-btn"
                data-id="{{order.id}}"
                data-status="{{order.orderStatus}}"
                bindtap="handlePrimaryAction"
              >
                {{order.primaryActionText}}
              </button>
              <button
                class="main-action-btn"
                data-id="{{order.id}}"
                data-status="{{order.orderStatus}}"
                bindtap="handleSecondaryAction"
              >
                {{order.secondaryActionText}}
              </button>
            </view>
          </view>
        </view>
      </view>

      <block wx:else>
        <block wx:for="{{filteredSections}}" wx:key="key">
          <view class="order-section {{item.colorClass}}">
            <view class="section-title-row" data-key="{{item.key}}" bindtap="toggleSection">
              <view class="section-left">
                <view class="section-dot"></view>
                <view class="section-title-text">{{item.title}}（{{item.count}}）</view>
                <view class="section-desc">{{item.desc}}</view>
              </view>
              <view class="section-fold">{{item.collapsed ? '展开' : '收起'}} {{item.collapsed ? '⌄' : '⌃'}}</view>
            </view>

            <view class="section-empty" wx:if="{{!item.count && !item.collapsed}}">
              <view class="section-empty-title">当前状态下没有订单</view>
              <view class="section-empty-desc">你可以切换其他状态看看</view>
            </view>

            <block wx:if="{{!item.collapsed}}">
              <view
                class="order-card section-order-card {{order.orderStatusClass}}"
                wx:for="{{item.orders}}"
                wx:for-item="order"
                wx:key="id"
              >
                <view class="order-main-row">
                  <view class="order-date-wrap">
                    <view class="order-date">{{order.serviceDateRangeText}}</view>
                  </view>
                  <view class="order-total">¥{{order.totalPriceText}}</view>
                </view>

                <view class="pet-line">
                  <view class="pet-avatar"></view>
                  <view class="pet-summary">{{order.petCountText || (order.petCount + '只宠物')}}</view>
                  <view class="order-status-badge">{{order.orderStatusDisplayText}}</view>
                </view>

                <view class="compact-info-row">
                  <view class="next-service-text">{{order.nextServiceText}}</view>
                  <view class="compact-divider"></view>
                  <view class="compact-meta">{{order.serviceMetaText}}</view>
                </view>

                <view class="progress-wrap" wx:if="{{order.showProgress}}">
                  <view class="progress-head">
                    <view class="progress-text">{{order.progressText}}</view>
                    <view class="progress-percent">{{order.progressPercent}}%</view>
                  </view>
                  <view class="progress-track">
                    <view class="progress-bar" style="width: {{order.progressPercent}}%;"></view>
                  </view>
                </view>

                <view class="address-row">
                  <view class="address-text">{{order.serviceFullAddress || '服务地址待确认'}}</view>
                </view>

                <view class="order-footer-row">
                  <view class="order-no">订单号：{{order.orderNo}}</view>
                  <view class="action-row compact-actions">
                    <button
                      class="plain-action-btn"
                      data-id="{{order.id}}"
                      data-status="{{order.orderStatus}}"
                      bindtap="handlePrimaryAction"
                    >
                      {{order.primaryActionText}}
                    </button>
                    <button
                      class="main-action-btn"
                      data-id="{{order.id}}"
                      data-status="{{order.orderStatus}}"
                      bindtap="handleSecondaryAction"
                    >
                      {{order.secondaryActionText}}
                    </button>
                  </view>
                </view>
              </view>
            </block>
          </view>
        </block>
      </block>

      <view class="page-bottom-space"></view>
    </block>
  </scroll-view>
</view>
