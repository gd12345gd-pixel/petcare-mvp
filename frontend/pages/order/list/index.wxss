page {
  background: linear-gradient(165deg, #fff8f9 0%, #f2f4f8 42%, #e8ecf2 100%);
}

.order-list-page {
  height: 100vh;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(165deg, #fff8f9 0%, #f2f4f8 42%, #e8ecf2 100%);
  color: #333333;
  box-sizing: border-box;
}

/* 顶部导航 */
.custom-nav {
  flex-shrink: 0;
  background: linear-gradient(180deg, #ffffff 0%, #fafcfd 100%);
  border-bottom: none;
  box-shadow: 0 4rpx 20rpx rgba(31, 35, 41, 0.06);
  box-sizing: border-box;
}

.nav-inner {
  position: relative;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.nav-title {
  position: absolute;
  left: 150rpx;
  right: 150rpx;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #111111;
  text-align: center;
}

.nav-back {
  position: absolute;
  left: 20rpx;
  top: 50%;
  width: 68rpx;
  height: 68rpx;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 34rpx;
  z-index: 2;
}

.nav-back--hover {
  background: #f5f6f8;
}

.nav-back__icon {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #222222;
  border-bottom: 4rpx solid #222222;
  transform: rotate(45deg);
  margin-left: 8rpx;
  box-sizing: border-box;
}

.nav-right {
  position: absolute;
  right: 20rpx;
  top: 50%;
  width: 140rpx;
  height: 68rpx;
  transform: translateY(-50%);
}

/* 顶部筛选：横向滑动胶囊（偏 C 端内容流，非后台表格） */
.tabs-shell {
  flex-shrink: 0;
  padding: 12rpx 0 4rpx;
  background: transparent;
  border-bottom: none;
  box-shadow: none;
  box-sizing: border-box;
  z-index: 5;
}

.tabs-scroll {
  width: 100%;
  height: 76rpx;
  box-sizing: border-box;
}

.tabs-row {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: center;
  height: 72rpx;
  padding: 0 20rpx 4rpx;
  box-sizing: border-box;
  gap: 16rpx;
}

.tab-chip {
  flex-shrink: 0;
  height: 64rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 64rpx;
  color: #5a5d66;
  text-align: center;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.95);
  box-shadow:
    0 4rpx 14rpx rgba(31, 35, 41, 0.06),
    0 0 0 1rpx rgba(255, 107, 129, 0.05);
}

.tab-chip--active {
  color: #ffffff;
  font-weight: 600;
  background: linear-gradient(135deg, #ff9eb0 0%, #ff6b81 42%, #ff5a8f 100%);
  border-color: rgba(255, 255, 255, 0.22);
  box-shadow:
    0 8rpx 22rpx rgba(255, 107, 129, 0.32),
    0 2rpx 8rpx rgba(255, 107, 129, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.35);
}

.tab-chip--pressed {
  transform: scale(0.97);
  opacity: 0.96;
}

/* 今日上门入口（Tab 下方固定条，不占 Tab 位） */
.today-strip {
  flex-shrink: 0;
  margin: 0 20rpx 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  box-sizing: border-box;
  background: linear-gradient(115deg, #fff8fb 0%, #fff0f4 40%, #ffffff 100%);
  border: 1rpx solid rgba(255, 107, 129, 0.14);
  box-shadow:
    0 4rpx 16rpx rgba(255, 107, 129, 0.1),
    0 2rpx 8rpx rgba(31, 35, 41, 0.04);
}

.today-strip--pressed {
  opacity: 0.92;
  transform: scale(0.99);
}

.today-strip__main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
}

.today-strip__icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  background: linear-gradient(145deg, #ffe8ef 0%, #ffd6e4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.65);
}

.today-strip__icon-cal {
  width: 22rpx;
  height: 22rpx;
  border: 2rpx solid #ff6b81;
  border-radius: 5rpx;
  box-sizing: border-box;
  position: relative;
  opacity: 0.9;
}

.today-strip__icon-cal::before {
  content: '';
  position: absolute;
  left: -2rpx;
  right: -2rpx;
  top: 6rpx;
  height: 2rpx;
  background: #ff6b81;
}

.today-strip__texts {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.today-strip__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333333;
  line-height: 40rpx;
}

.today-strip__sub {
  font-size: 22rpx;
  color: #999999;
  line-height: 32rpx;
}

.today-strip__action {
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 600;
  color: #ff5a72;
  line-height: 40rpx;
}

/* 内容 */
.content {
  flex: 1;
  height: 0;
  box-sizing: border-box;
  background: transparent;
}

/* loading */
.loading-wrap {
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

.loading-text {
  margin-top: 22rpx;
  font-size: 25rpx;
  color: #999999;
  text-align: center;
}

.skeleton-card {
  padding: 22rpx;
  border-radius: 28rpx;
  background: linear-gradient(165deg, #ffffff 0%, #fafbfc 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  box-shadow:
    0 4rpx 14rpx rgba(31, 35, 41, 0.06),
    0 16rpx 40rpx rgba(31, 35, 41, 0.05);
  box-sizing: border-box;
}

.skeleton-top {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.skeleton-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 16rpx;
  background: #f1f2f5;
  flex-shrink: 0;
}

.skeleton-main {
  flex: 1;
  min-width: 0;
  padding-top: 4rpx;
}

.skeleton-line {
  height: 20rpx;
  border-radius: 999rpx;
  background: #f1f2f5;
}

.skeleton-line--lg {
  width: 58%;
}

.skeleton-line--md {
  width: 42%;
  margin-top: 16rpx;
}

.skeleton-line--full {
  width: 100%;
  margin-top: 24rpx;
}

.skeleton-line--short {
  width: 38%;
  margin-top: 20rpx;
}

/* 空状态 */
.empty-wrap {
  padding: 210rpx 48rpx 0;
  text-align: center;
  box-sizing: border-box;
}

.empty-icon {
  width: 128rpx;
  height: 128rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: linear-gradient(160deg, #ffffff 0%, #fff0f3 100%);
  box-shadow:
    0 6rpx 20rpx rgba(255, 107, 129, 0.12),
    0 2rpx 8rpx rgba(31, 35, 41, 0.06),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.95);
  font-size: 62rpx;
  line-height: 128rpx;
}

.empty-title {
  margin-top: 26rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #222222;
  line-height: 44rpx;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #999999;
  line-height: 40rpx;
}

.empty-btn {
  width: 252rpx;
  height: 72rpx;
  margin: 34rpx auto 0;
  padding: 0;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ff8a9b 0%, #ff6b81 50%, #ff5570 100%);
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 72rpx;
  box-shadow:
    0 8rpx 22rpx rgba(255, 107, 129, 0.35),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.3);
}

.empty-btn::after {
  border: none;
}

/* 状态空卡 */
.state-card {
  margin: 22rpx 24rpx 0;
  padding: 52rpx 34rpx;
  border-radius: 28rpx;
  background: linear-gradient(165deg, #ffffff 0%, #fafbfc 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow:
    0 4rpx 16rpx rgba(31, 35, 41, 0.06),
    0 18rpx 48rpx rgba(31, 35, 41, 0.05);
  text-align: center;
  box-sizing: border-box;
}

.state-card__icon {
  font-size: 52rpx;
  line-height: 1;
}

.state-card__title {
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  line-height: 42rpx;
}

.state-card__desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #999999;
  line-height: 38rpx;
}

/* 列表 */
.order-list {
  padding: 20rpx 24rpx 0;
  box-sizing: border-box;
}

.list-end {
  padding: 6rpx 0 0;
  font-size: 24rpx;
  color: #b8b8b8;
  text-align: center;
  line-height: 42rpx;
}

.page-bottom-space {
  height: 150rpx;
}

/* 订单卡片：偏亮白表面 + 极轻暖粉氛围，与 page 渐变区分更清晰 */
.order-card {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(
    152deg,
    #ffffff 0%,
    #fffdfd 14%,
    #fff9fb 32%,
    #faf7f9 68%,
    #f5f3f7 100%
  );
  border: 1rpx solid rgba(255, 255, 255, 0.92);
  box-shadow:
    0 0 0 1rpx rgba(255, 107, 129, 0.06),
    0 2rpx 10rpx rgba(31, 35, 41, 0.04),
    0 14rpx 40rpx rgba(31, 35, 41, 0.07),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.95);
  box-sizing: border-box;
  overflow: hidden;
}

.order-card--inset {
  margin: 0 16rpx 16rpx;
  background: linear-gradient(
    152deg,
    #fefcfd 0%,
    #fff6f8 28%,
    #f7f5f8 100%
  );
  border: 1rpx solid rgba(255, 255, 255, 0.75);
  box-shadow:
    0 0 0 1rpx rgba(255, 107, 129, 0.05),
    0 2rpx 8rpx rgba(31, 35, 41, 0.035),
    0 10rpx 28rpx rgba(31, 35, 41, 0.05);
}

.order-card__top {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.order-card__avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #f0f2f5 0%, #e8eaef 100%);
  flex-shrink: 0;
  overflow: hidden;
  box-shadow:
    0 4rpx 12rpx rgba(31, 35, 41, 0.1),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.65);
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  box-sizing: border-box;
}

.order-card__avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #ffeef2 0%, #ffd6e0 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.75);
}

.order-card__avatar-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #ff6b81;
  line-height: 1;
}

.order-card__main {
  flex: 1;
  min-width: 0;
}

.order-card__title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.order-card__title {
  flex: 1;
  min-width: 0;
  font-size: 29rpx;
  font-weight: 700;
  color: #222222;
  line-height: 40rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.order-card__price {
  flex-shrink: 0;
  font-size: 33rpx;
  font-weight: 800;
  color: #ff5a72;
  line-height: 40rpx;
  text-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.6);
}

.order-card__meta-row {
  margin-top: 10rpx;
  min-height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.order-card__date {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.calendar-icon {
  position: relative;
  width: 22rpx;
  height: 22rpx;
  border: 2rpx solid #a0a0a0;
  border-radius: 5rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.calendar-icon::before {
  content: '';
  position: absolute;
  left: -2rpx;
  right: -2rpx;
  top: 6rpx;
  height: 2rpx;
  background: #a0a0a0;
}

.calendar-icon::after {
  content: '';
  position: absolute;
  left: 5rpx;
  top: -5rpx;
  width: 9rpx;
  height: 6rpx;
  border-left: 2rpx solid #a0a0a0;
  border-right: 2rpx solid #a0a0a0;
  box-sizing: border-box;
}

.order-card__date-text {
  flex: 1;
  min-width: 0;
  font-size: 23rpx;
  color: #666666;
  line-height: 32rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* 状态标签（仅文字色，无底色块） */
.order-card__tag {
  flex-shrink: 0;
  max-width: 210rpx;
  min-height: 34rpx;
  padding: 0;
  border-radius: 0;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 32rpx;
  white-space: nowrap;
  box-sizing: border-box;
  background: transparent;
  border: none;
  box-shadow: none;
}

.tag-today-done {
  background: transparent;
  color: #1677d9;
  border: none;
}

.tag-today-serving,
.tag-in-progress {
  background: transparent;
  color: #d97706;
  border: none;
}

.tag-wait-arrival,
.tag-pending {
  background: transparent;
  color: #e84a6a;
  border: none;
}

.tag-muted {
  background: transparent;
  color: #888888;
  border: none;
}

.tag-default {
  background: transparent;
  color: #555555;
  border: none;
}

/* 下次服务提示 */
.order-card__notice {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  background: linear-gradient(100deg, #fff8fb 0%, #fff0f4 100%);
  border: 1rpx solid rgba(255, 107, 129, 0.12);
  display: flex;
  align-items: center;
  gap: 9rpx;
  box-sizing: border-box;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.order-card__notice-dot {
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: #ff6b81;
  flex-shrink: 0;
}

.order-card__notice-text {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: #666666;
  line-height: 32rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* 进度 */
.order-card__progress {
  margin-top: 18rpx;
}

.order-card__notice + .order-card__progress {
  margin-top: 14rpx;
}

.order-card__progress-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 10rpx;
}

.order-card__progress-text {
  flex: 1;
  min-width: 0;
  font-size: 23rpx;
  color: #666666;
  line-height: 32rpx;
}

.order-card__progress-percent {
  flex-shrink: 0;
  font-size: 23rpx;
  color: #999999;
  line-height: 32rpx;
}

.order-card__progress-track {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #e9ebef 0%, #f3f4f7 100%);
  overflow: hidden;
  box-shadow: inset 0 2rpx 4rpx rgba(31, 35, 41, 0.08);
}

.order-card__progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #ff8a9b 0%, #ff6b81 45%, #ff5a78 100%);
  box-shadow: 0 0 8rpx rgba(255, 107, 129, 0.35);
}

/* 底部 */
.order-card__footer {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(255, 107, 129, 0.08);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.order-card__no {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: #999999;
  line-height: 52rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.order-card__actions {
  flex: 0 0 auto;
  flex-shrink: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  max-width: 52%;
  box-sizing: border-box;
}

.order-action {
  flex: 0 0 auto;
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  width: auto !important;
  min-width: 0;
  height: 52rpx;
  margin: 0;
  padding: 0 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1;
  text-align: center;
  box-sizing: border-box;
}

.order-action::after {
  border: none;
}

.order-action--plain {
  background: linear-gradient(165deg, #fffcfc 0%, #fff8f9 40%, #fdf5f7 100%);
  color: #5c4750;
  border: 1rpx solid rgba(255, 150, 168, 0.35);
  box-shadow:
    0 4rpx 14rpx rgba(255, 107, 129, 0.08),
    0 1rpx 4rpx rgba(31, 35, 41, 0.03),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

.order-action--primary {
  background: linear-gradient(180deg, #ff8a9b 0%, #ff6b81 48%, #ff5570 100%);
  color: #ffffff;
  border: 1rpx solid rgba(255, 90, 112, 0.5);
  box-shadow:
    0 4rpx 14rpx rgba(255, 107, 129, 0.32),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.28);
}

/* 分组 */
.order-section {
  margin: 20rpx 24rpx 0;
  border-radius: 28rpx;
  background: linear-gradient(165deg, #ffffff 0%, #f8f9fb 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  box-shadow:
    0 4rpx 14rpx rgba(31, 35, 41, 0.06),
    0 14rpx 40rpx rgba(31, 35, 41, 0.05);
  overflow: hidden;
}

.order-section__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.6) 0%, rgba(248, 249, 251, 0.4) 100%);
  box-sizing: border-box;
}

.order-section__left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.order-section__dot {
  width: 9rpx;
  height: 9rpx;
  border-radius: 50%;
  background: #ff6b81;
  flex-shrink: 0;
}

.section-wait-taking .order-section__dot {
  background: #ff6b81;
}

.section-serving .order-section__dot {
  background: #fa8c16;
}

.section-completed .order-section__dot {
  background: #999999;
}

.section-cancelled .order-section__dot {
  background: #999999;
}

.order-section__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333333;
  line-height: 38rpx;
}

.order-section__desc {
  width: 100%;
  padding-left: 20rpx;
  font-size: 22rpx;
  color: #999999;
  line-height: 32rpx;
  box-sizing: border-box;
}

.order-section__fold {
  flex-shrink: 0;
  font-size: 23rpx;
  color: #999999;
  line-height: 34rpx;
}

.order-section__body {
  padding: 16rpx 0 0;
  box-sizing: border-box;
}

.section-empty {
  margin: 16rpx;
  padding: 44rpx 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f6f8fa 0%, #eceef2 100%);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  text-align: center;
  box-sizing: border-box;
  box-shadow: inset 0 2rpx 6rpx rgba(31, 35, 41, 0.04);
}

.section-empty__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333333;
  line-height: 40rpx;
}

.section-empty__desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #999999;
  line-height: 36rpx;
}