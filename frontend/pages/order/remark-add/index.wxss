.remark-add-page {
  min-height: 100vh;
  background: #f7f8fb;
  padding-bottom: 170rpx;
  box-sizing: border-box;
}

.custom-nav {
  background: #fff7fa;
  border-bottom: 1rpx solid #f2e6eb;
  box-sizing: border-box;
}

.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.nav-side {
  width: 96rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #111;
}

.nav-back-hit {
  width: 96rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 22rpx;
  height: 22rpx;
  border-left: 5rpx solid #222;
  border-bottom: 5rpx solid #222;
  transform: rotate(45deg);
  margin-left: 8rpx;
  box-sizing: border-box;
}

.hero-card,
.tip-card,
.form-card {
  margin: 16rpx 16rpx 0;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 4rpx 14rpx rgba(31, 35, 41, 0.04);
  box-sizing: border-box;
}

.hero-card {
  background: linear-gradient(180deg, #f8dfe7 0%, #fff4f7 100%);
}

.hero-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #222;
}

.hero-desc,
.tip-item {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7f858f;
  line-height: 1.55;
}

.tip-title,
.form-label {
  font-size: 28rpx;
  font-weight: 800;
  color: #222;
}

.form-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.count-text {
  font-size: 22rpx;
  color: #a0a4ad;
}

.remark-textarea {
  width: 100%;
  min-height: 220rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f8f9fc;
  color: #222;
  font-size: 26rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.placeholder {
  color: #b8bcc5;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item,
.image-add {
  position: relative;
  width: 190rpx;
  height: 190rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: #f8f9fc;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 28rpx;
  line-height: 34rpx;
  text-align: center;
}

.image-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #ffd0dc;
  color: #ff5f8d;
}

.image-add-icon {
  font-size: 48rpx;
  line-height: 1;
}

.image-add-text {
  margin-top: 12rpx;
  font-size: 24rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -6rpx 20rpx rgba(31, 35, 41, 0.06);
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
}

.page-bottom-space {
  height: 30rpx;
}
