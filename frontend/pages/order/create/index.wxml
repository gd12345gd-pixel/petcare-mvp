<view class="order-create-page">
  <view class="custom-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-side nav-left" bindtap="navigateBack">
        <view class="nav-back-hit">
          <text class="nav-back-icon">‹</text>
        </view>
      </view>
      <view class="nav-title">下单预约</view>
      <view class="nav-side"></view>
    </view>
  </view>

  <scroll-view
    class="content"
    scroll-y
    style="height: calc(100vh - {{navTotalHeight}}px - 170rpx);"
  >
    <view class="hero-card">
      <view class="hero-badge">预约上门喂养</view>
      <view class="hero-title">下单预约</view>
      <view class="hero-desc">填写毛孩子的照护信息，我们会尽快为你确认服务</view>
    </view>

    <view class="form-card">
      <view class="form-row form-row-arrow" bindtap="goChooseAddress">
        <view class="form-row-left">
          <view class="form-title-line">
            <view class="form-label">服务地址</view>
            <view class="row-status-tag {{selectedAddress ? 'filled' : ''}}">
              {{selectedAddress ? '已选择' : '待填写'}}
            </view>
          </view>

          <block wx:if="{{selectedAddress}}">
            <view class="address-info-card">
              <view class="address-contact-line">
                <view class="address-contact-name">{{selectedAddress.contactName}}</view>
                <view class="address-contact-phone">{{selectedAddress.contactPhone}}</view>
              </view>
              <view class="address-full-text">
                {{selectedAddress.fullAddress || (selectedAddress.province + selectedAddress.city + selectedAddress.district + selectedAddress.detailAddress)}}
              </view>
            </view>
          </block>

          <block wx:else>
            <view class="select-placeholder-card">
              <view class="select-placeholder-title">请选择服务地址</view>
              <view class="select-placeholder-desc">用于安排上门服务地点</view>
            </view>
          </block>
        </view>
        <view class="form-arrow">›</view>
      </view>

      <view class="form-divider"></view>

      <view class="form-block">
        <view class="block-head">
          <view class="form-label">服务宠物</view>
          <view class="inline-tag">已选 {{selectedPetIds.length}} 只</view>
        </view>

        <scroll-view class="pet-scroll" scroll-x wx:if="{{pets.length}}">
          <view class="pet-row">
            <view
              class="pet-card {{item.selected ? 'active' : ''}}"
              wx:for="{{pets}}"
              wx:key="id"
              data-id="{{item.id}}"
              bindtap="selectPet"
            >
              <view class="pet-check" wx:if="{{item.selected}}">✓</view>

              <image
                class="pet-card-image {{item.selected ? 'pet-card-image--active' : ''}}"
                src="{{item.avatarUrl || item.imageUrl || defaultPetImage}}"
                mode="aspectFill"
              />
              <view class="pet-card-name">{{item.name}}</view>
              <view class="pet-card-meta">
                {{item.type}}{{item.breed ? ' · ' + item.breed : ''}}
              </view>
            </view>

            <view class="pet-card add-card" bindtap="goAddPet">
              <view class="add-circle">+</view>
              <view class="add-text">添加宠物</view>
            </view>
          </view>
        </scroll-view>

        <view class="pet-empty-wrap" wx:else>
          <view class="empty-title">请选择服务宠物</view>
          <view class="empty-desc">还没有添加宠物，先新增一个吧</view>
          <button class="primary-btn pet-empty-btn" bindtap="goAddPet">新增宠物</button>
        </view>
      </view>

      <view class="form-divider"></view>

      <view class="form-row form-row-arrow" bindtap="openDatePopup">
        <view class="form-row-left">
          <view class="form-title-line">
            <view class="form-label">服务日期</view>
            <view class="row-status-tag {{selectedDates.length ? 'filled' : ''}}">
              {{selectedDates.length ? ('已选' + selectedDates.length + '天') : '待选择'}}
            </view>
          </view>

          <block wx:if="{{selectedDates.length}}">
            <view class="date-info-card">
              <view class="date-summary-main">{{selectedDateSummary}}</view>
              <view class="date-summary-sub">可多选日期，提交后进入待接单状态</view>
            </view>
          </block>

          <block wx:else>
            <view class="select-placeholder-card">
              <view class="select-placeholder-title">请选择服务日期</view>
              <view class="select-placeholder-desc">支持多选，方便一次预约多天服务</view>
            </view>
          </block>
        </view>
        <view class="form-arrow">›</view>
      </view>

      <view class="form-divider"></view>

      <view class="form-block">
        <view class="block-head">
          <view class="form-label">上门时间段</view>
          <view class="section-tip">可多选</view>
        </view>

        <view class="time-section-wrap">
          <view class="time-primary-row">
            <view
              class="time-pill time-pill-any {{timeSlots[0].selected ? 'active' : ''}}"
              data-value="{{timeSlots[0].value}}"
              bindtap="toggleTimeSlot"
            >
              {{timeSlots[0].label}}
            </view>
          </view>

          <view class="time-subtitle">推荐时间段</view>

          <view class="time-grid">
            <view
              class="time-card {{item.selected ? 'active' : ''}}"
              wx:for="{{timeSlots}}"
              wx:if="{{index > 0}}"
              wx:key="value"
              data-value="{{item.value}}"
              bindtap="toggleTimeSlot"
            >
              {{item.label}}
            </view>
          </view>
        </view>

        <view class="field-tip">若选择“时间不限”，则只能单选；其他时间段支持多选</view>
      </view>

      <view class="form-divider"></view>

      <view class="form-block">
        <view class="block-head">
          <view class="form-label">服务时长</view>
          <view class="section-tip">分钟</view>
        </view>

        <view class="slot-grid duration-grid">
          <view
            class="slot-item duration-item {{item.active ? 'active' : ''}}"
            wx:for="{{durationQuickOptions}}"
            wx:key="value"
            data-value="{{item.value}}"
            bindtap="chooseDuration"
          >
            {{item.label}}
          </view>
        </view>

        <view class="custom-duration-panel" wx:if="{{showCustomDuration}}">
          <view class="custom-duration-header">
            <view class="desc-mini">自定义时长</view>
            <view class="custom-duration-value">{{durationMinutes}} 分钟</view>
          </view>

          <view class="duration-stepper-wrap">
            <view class="stepper">
              <view class="step-btn" bindtap="decreaseDuration">-</view>
              <view class="step-value">{{durationMinutes}}</view>
              <view class="step-btn" bindtap="increaseDuration">+</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="form-card">
      <view class="form-block">
        <view class="block-head">
          <view class="form-label">单次服务价格</view>
          <view class="section-tip">支持调整</view>
        </view>

        <view class="price-panel">
          <view class="price-row">
            <view class="price-label">平台建议价</view>
            <view class="price-value">¥{{suggestedUnitPrice}}</view>
          </view>

          <view class="price-row">
            <view class="price-label">你确认的单次价</view>
            <view class="price-input-wrap">
              <text class="price-symbol">¥</text>
              <input
                class="price-input"
                type="digit"
                value="{{unitPrice}}"
                bindinput="onUnitPriceInput"
              />
            </view>
          </view>

          <view class="price-actions" wx:if="{{unitPriceTouched}}">
            <view class="price-touched-tip">你已手动调整单次价格</view>
            <view class="sync-price-btn" bindtap="syncUnitPriceToSuggested">同步建议价</view>
          </view>
        </view>

        <view class="field-tip">平台会根据服务信息更新建议价；你手动确认的价格不会被自动覆盖</view>
      </view>

      <view class="form-divider"></view>

      <view class="form-block">
        <view class="block-head">
          <view class="form-label">照护备注</view>
        </view>

        <textarea
          class="note-textarea"
          placeholder="可填写宠物习性、喂养方式、注意事项、是否怕生等"
          placeholder-class="input-placeholder"
          value="{{remark}}"
          bindinput="onRemarkInput"
          maxlength="300"
        ></textarea>
        <view class="remark-count">{{remark.length}}/300</view>
      </view>
    </view>

    <view class="summary-card">
      <view class="summary-head">
        <view class="form-label">费用明细</view>
        <view class="section-tip">自动计算</view>
      </view>

      <view class="summary-row">
        <text class="summary-label">单次价格</text>
        <text class="summary-value">¥{{unitPriceDisplay}}</text>
      </view>

      <view class="summary-row">
        <text class="summary-label">服务次数</text>
        <text class="summary-value">{{serviceCount}}次</text>
      </view>

      <view class="summary-total-box">
        ¥{{unitPriceDisplay}} × {{serviceCount}}次 = ¥{{totalPriceDisplay}}
      </view>

      <view class="field-tip">提交后进入待接单状态</view>
    </view>

    <view class="page-bottom-space"></view>
  </scroll-view>

  <view class="bottom-bar order-bottom-bar">
    <view class="bottom-info">
      <view class="bottom-total">总价 ¥{{totalPriceDisplay}}</view>
      <view class="bottom-desc">提交后进入待接单</view>
    </view>
    <button class="primary-btn order-submit-btn" bindtap="submitOrder">确认下单</button>
  </view>

  <view class="mask" wx:if="{{showDatePopup}}" bindtap="closeDatePopup"></view>
  <view class="date-popup" wx:if="{{showDatePopup}}">
    <view class="date-popup-body">
      <view class="date-popup-header">
        <view class="popup-title">{{calendarMonthText}}</view>
        <view class="date-popup-close" bindtap="closeDatePopup">✕</view>
      </view>

      <view class="week-row">
        <view class="week-item">日</view>
        <view class="week-item">一</view>
        <view class="week-item">二</view>
        <view class="week-item">三</view>
        <view class="week-item">四</view>
        <view class="week-item">五</view>
        <view class="week-item weekend">六</view>
      </view>

      <view class="calendar-grid">
        <view
          wx:for="{{calendarDays}}"
          wx:key="id"
          class="day-cell {{item.empty ? 'empty' : ''}} {{item.selected ? 'selected' : ''}}"
          data-date="{{item.date}}"
          bindtap="toggleCalendarDate"
        >
          <block wx:if="{{!item.empty}}">
            <view class="day-num">{{item.day}}</view>
          </block>
        </view>
      </view>

      <view class="date-selected-summary" wx:if="{{tempSelectedDates.length}}">
        已选：{{tempSelectedDateSummary}}
      </view>
    </view>

    <view class="date-popup-footer">
      <button class="secondary-btn popup-cancel-btn" bindtap="closeDatePopup">取消</button>
      <button class="pink-btn popup-confirm-btn" bindtap="confirmDateSelection">确定</button>
    </view>
  </view>
</view>