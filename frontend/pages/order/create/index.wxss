.order-create-page {
  background: #f7f8fb;
}

.content {
  height: calc(100vh - 96rpx - 156rpx);
}

.hero-card {
  margin: 20rpx 16rpx 0;
  padding: 30rpx 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f8dfe7 0%, #fff4f7 100%);
}

.hero-desc {
  margin-top: 10rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-head-desc {
  flex-shrink: 0;
}

.address-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 120rpx;
}

.address-main {
  flex: 1;
  min-width: 0;
}

.address-title {
  line-height: 1.45;
}

.address-sub {
  margin-top: 10rpx;
}

.pet-scroll {
  margin-top: 8rpx;
  white-space: nowrap;
}

.pet-row {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 8rpx;
}

.pet-card {
  width: 180rpx;
  background: #f8f9fc;
  border-radius: 22rpx;
  padding: 16rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

.pet-card.active {
  background: #fff7f9;
  border-color: #ff9ab0;
  box-shadow: 0 8rpx 20rpx rgba(255, 122, 160, 0.12);
}

.pet-card-image {
  width: 100%;
  height: 124rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
}

.pet-card-name {
  margin-top: 12rpx;
  line-height: 1.3;
}

.pet-card-meta {
  margin-top: 6rpx;
}

.add-card {
  border: 2rpx dashed #d8dde6;
  background: #fafbfc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid #d0d5dd;
  color: #8f96a3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  line-height: 1;
}

.add-text {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1;
}

.pet-empty-wrap {
  margin-top: 8rpx;
  background: #fafbfc;
  border-radius: 22rpx;
  padding: 36rpx 24rpx;
  text-align: center;
}

.pet-empty-btn {
  margin: 18rpx auto 0;
  width: 220rpx;
}

.date-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.date-item {
  width: calc((100% - 32rpx) / 3);
  min-height: 104rpx;
  border-radius: 18rpx;
  background: #f8f9fc;
  border: 2rpx solid transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.date-item.active {
  background: #fff7f9;
  border-color: #ff9ab0;
  box-shadow: 0 8rpx 18rpx rgba(255, 95, 141, 0.1);
}

.date-item-day {
  font-size: 30rpx;
  font-weight: 800;
  color: #222;
  line-height: 1.2;
}

.date-item-week {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8c8c8c;
  line-height: 1.2;
}

.date-item.active .date-item-day,
.date-item.active .date-item-week {
  color: #ff5f8d;
}

.slot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.slot-item {
  min-width: 204rpx;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  background: #fff;
  border: 2rpx solid #eceef2;
  color: #666;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.slot-item.active {
  border-color: #ff6b81;
  color: #ff6b81;
  background: #fff7f9;
}

.field-tip {
  margin-top: 14rpx;
}

.duration-main {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 18rpx;
}

.stepper {
  display: flex;
  align-items: center;
  border: 2rpx solid #eceef2;
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
}

.step-btn,
.step-value {
  width: 72rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #222;
}

.step-btn {
  background: #fafbfc;
}

.duration-grid .duration-item {
  min-width: 160rpx;
}

.price-panel {
  background: #f8f9fc;
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-row + .price-row {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #edf0f4;
}

.price-value {
  font-size: 34rpx;
  font-weight: 800;
  color: #222;
}

.price-input-wrap {
  min-width: 180rpx;
  height: 68rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: #fff;
  border: 2rpx solid #eceef2;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.price-symbol {
  font-size: 28rpx;
  color: #222;
  margin-right: 6rpx;
}

.price-input {
  width: 120rpx;
  text-align: right;
  font-size: 32rpx;
  font-weight: 800;
  color: #222;
}

.note-textarea {
  min-height: 200rpx;
}

.remark-count {
  text-align: right;
  margin-top: 12rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-row + .summary-row {
  margin-top: 16rpx;
}

.summary-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #222;
}

.summary-total-box {
  margin-top: 22rpx;
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  background: #fff1f5;
  color: #ff5f8d;
  font-size: 30rpx;
  font-weight: 800;
  text-align: center;
  line-height: 1.4;
}

.order-bottom-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.bottom-info {
  flex: 1;
  min-width: 0;
}

.bottom-price {
  font-size: 32rpx;
  font-weight: 800;
  color: #ff5f8d;
  line-height: 1.2;
}

.bottom-desc {
  margin-top: 8rpx;
}

.order-submit-btn {
  width: 260rpx;
  flex-shrink: 0;
}

.selector-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 104rpx;
}

.selector-left {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.selector-title {
  line-height: 1.4;
}

.selector-right {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.selector-value-wrap {
  min-width: 0;
  max-width: 420rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.selector-value {
  font-size: 26rpx;
  color: #b3b7c0;
  line-height: 1.5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: right;
}

.selector-value.active {
  color: #222;
}

.custom-duration-panel {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f8f9fc;
}

.custom-duration-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.custom-duration-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #ff5f8d;
}

.mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 99;
}

.date-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  z-index: 100;
  padding: 24rpx 24rpx 30rpx;
  box-sizing: border-box;
  max-height: 82vh;
  overflow-y: auto;
}

.date-popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date-popup-close {
  font-size: 30rpx;
  color: #b4b4b4;
  width: 48rpx;
  text-align: center;
}

.week-row {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
}

.week-item {
  text-align: center;
  font-size: 24rpx;
  color: #808080;
  padding: 10rpx 0;
}

.weekend {
  color: #ff6b81;
}

.calendar-grid {
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx 6rpx;
}

.day-cell {
  height: 78rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.day-cell.empty {
  visibility: hidden;
}

.day-cell.selected {
  background: #ff6b81;
  color: #fff;
}

.day-num {
  font-size: 28rpx;
  font-weight: 600;
}

.date-selected-summary {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #fff7f9;
  font-size: 24rpx;
  color: #ff5f8d;
  line-height: 1.6;
}

.date-popup-btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}

.popup-cancel-btn,
.popup-confirm-btn {
  flex: 1;
}