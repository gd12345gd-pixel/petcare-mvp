<view class="page-with-bottom-bar">
  <view class="nav-bar address-nav">
    <view class="back-area" bindtap="navigateBack">
      <view class="back-icon"></view>
    </view>
    <view class="nav-title">{{isEdit ? '编辑收货地址' : '新增收货地址'}}</view>
    <view class="feedback-link">反馈问题</view>
  </view>

  <view class="content">
    <view class="map-preview" bindtap="chooseRegionByMap">
      <view class="map-road road-one"></view>
      <view class="map-road road-two"></view>
      <view class="map-pin"></view>
      <view class="map-address-name">{{form.addressName || '点击选择地图位置'}}</view>
    </view>

    <view class="paste-card">
      <view class="paste-placeholder">粘贴文本，智能识别地址信息</view>
      <button class="paste-btn" bindtap="pasteAddress">粘贴</button>
    </view>

    <view class="form-panel">
      <view class="form-row address-row" bindtap="chooseRegionByMap">
        <view class="row-label">地址</view>
        <view class="row-main">
          <view class="address-title {{form.addressName ? '' : 'placeholder'}}">
            {{form.addressName || '请选择小区/楼栋/地点'}}
          </view>
          <view class="address-sub" wx:if="{{form.addressText || form.regionText}}">
            {{form.addressText || form.regionText}}
          </view>
        </view>
        <view class="row-arrow">›</view>
      </view>

      <view class="form-row">
        <view class="row-label">门牌号</view>
        <input
          class="row-input"
          placeholder="填写详细地址，例:1层102室"
          placeholder-class="input-placeholder"
          value="{{form.detailAddress}}"
          data-field="detailAddress"
          bindinput="onInput"
        />
      </view>

      <view class="form-row">
        <view class="row-label">收货人</view>
        <input
          class="row-input"
          placeholder="填写收货人姓名"
          placeholder-class="input-placeholder"
          value="{{form.contactName}}"
          data-field="contactName"
          bindinput="onInput"
        />
        <view class="gender-group">
          <view class="gender-item {{form.gender === '先生' ? 'active' : ''}}" data-gender="先生" bindtap="chooseGender">先生</view>
          <view class="gender-item {{form.gender === '女士' ? 'active' : ''}}" data-gender="女士" bindtap="chooseGender">女士</view>
        </view>
      </view>

      <view class="form-row no-border">
        <view class="row-label">手机号</view>
        <view class="country-code">+86⌄</view>
        <input
          class="row-input"
          type="number"
          placeholder="请输入联系电话"
          placeholder-class="input-placeholder"
          value="{{form.contactPhone}}"
          data-field="contactPhone"
          bindinput="onInput"
        />
      </view>
    </view>

    <view class="tag-panel">
      <view class="tag-title">标签</view>
      <view class="tag-row">
        <view class="tag-chip {{form.tagName === item ? 'active' : ''}}" wx:for="{{tagOptions}}" wx:key="*this" data-tag="{{item}}" bindtap="chooseTag">
          {{item}}
        </view>
      </view>
    </view>

    <view class="default-panel">
      <view>
        <view class="default-title">设为默认地址</view>
        <view class="default-desc">下单时优先使用该服务地址</view>
      </view>
        <switch checked="{{form.isDefault === 1}}" bindchange="switchDefault" color="#ff6b81" />
    </view>
  </view>

  <view class="bottom-bar">
    <button class="primary-btn save-btn" bindtap="saveAddress">
      {{isEdit ? '保存修改' : '保存地址'}}
    </button>
  </view>
</view>